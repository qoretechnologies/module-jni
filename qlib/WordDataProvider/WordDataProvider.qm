# minimum required Qore version
%requires qore >= 1.0
# assume local scope for variables, do not use "$" signs
%new-style
# require type definitions everywhere
%require-types
# strict argument handling
%strict-args
# enable all warnings
%enable-all-warnings

# supports using the DataProvider module
%requires(reexport) DataProvider
%requires Util

%module-cmd(jni) add-relative-classpath ./jar/qore-dataprovider-word.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-full-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-compress-1.28.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-io-2.20.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-codec-1.19.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-lang3-3.18.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-math3-3.6.1.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/curvesapi-1.08.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/xmlbeans-5.3.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-collections4-4.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/log4j-api-2.24.3.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/SparseBitSet-1.3.jar

%module-cmd(jni) import org.qore.dataprovider.word.WordIterator
%module-cmd(jni) import org.qore.dataprovider.word.WordWriter

module WordDataProvider {
    version = "1.0";
    desc = "user module providing a data provider API for reading and writing Word documents";
    author = "David Nichols <david@qore.org>";
    url = "http://qore.org";
    license = "MIT";
    init = sub () {
        # register the data provider factories
        DataProvider::registerFactory(new WordReadDataProviderFactory());
        DataProvider::registerFactory(new WordWriteDataProviderFactory());

        # register the data provider application
        DataProviderActionCatalog::registerApp(<DataProviderAppInfo>{
            "name": WordDataProvider::AppName,
            "display_name": "Word Documents",
            "short_desc": "Read and write Microsoft Word documents",
            "desc": "Read and write Microsoft Word documents (.docx format)",
            "logo": WordLogo,
            "logo_file_name": "word-logo.svg",
            "logo_mime_type": MimeTypeSvg,
        });

        # register all supported actions
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": WordDataProvider::AppName,
            "path": "/",
            "action": "read",
            "display_name": "Read Word Document File",
            "short_desc": "Read Word document from a specific file location",
            "desc": "Read Word document from a specific file location",
            "action_code": DPAT_FIND,
            "cls": "WordDataProvider::WordReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                WordReadDataProvider::ConstructorOptions{"path", "content_type", "table_index", "header_row"}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                WordReadDataProvider::ConstructorOptions - ("path", "content_type", "table_index", "header_row",
                    "stream", "data"), {
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": WordDataProvider::AppName,
            "path": "/",
            "action": "read-data",
            "display_name": "Read Word Document Inline Data",
            "short_desc": "Read Word document inline data",
            "desc": "Read Word document inline data",
            "action_code": DPAT_FIND,
            "cls": "WordDataProvider::WordReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                WordReadDataProvider::ConstructorOptions{"data", "content_type", "table_index", "header_row"}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                WordReadDataProvider::ConstructorOptions - ("path", "content_type", "table_index", "header_row",
                    "stream", "data"), {
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": WordDataProvider::AppName,
            "path": "/",
            "action": "write",
            "display_name": "Write Word Document File",
            "short_desc": "Write data to a Word document file",
            "desc": "Write data to a Word document file at a specified path",
            "action_code": DPAT_CREATE,
            "cls": "WordDataProvider::WordWriteDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                WordWriteDataProvider::ConstructorOptions{"path", "content_type", "headers", "title"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": WordDataProvider::AppName,
            "path": "/",
            "action": "write-data",
            "display_name": "Create Word Document Data",
            "short_desc": "Create Word document data and return as binary",
            "desc": "Create Word document data in memory and return it as binary data; useful for generating "
                "Word files without writing to disk",
            "action_code": DPAT_CREATE,
            "cls": "WordDataProvider::WordWriteDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                WordWriteDataProvider::ConstructorOptions{"content_type", "headers", "title"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });
    };
}

/** @mainpage WordDataProvider Module

    @tableofcontents

    @section WordDataProviderintro Introduction to the WordDataProvider Module

    The %WordDataProvider module provides a data provider API for reading and writing Microsoft Word documents
    through the @ref dataproviderintro "DataProvider" API. It supports the modern .docx format (Word 2007+)
    using Apache POI's XWPF library.

    The following classes are provided by this module:
    - @ref WordDataProvider::WordReadDataProvider "WordReadDataProvider" - for reading Word documents
    - @ref WordDataProvider::WordReadDataProviderFactory "WordReadDataProviderFactory" - factory for read providers
    - @ref WordDataProvider::WordWriteDataProvider "WordWriteDataProvider" - for writing Word documents
    - @ref WordDataProvider::WordWriteDataProviderFactory "WordWriteDataProviderFactory" - factory for write providers

    @section WordDataProvider_reading Reading Word Documents

    @subsection WordDataProvider_reading_paragraphs Reading Paragraphs

    @code{.py}
    %requires WordDataProvider

    # Read paragraphs from a file path
    WordReadDataProvider dp("document.docx", {"content_type": "paragraphs"});
    list<hash<auto>> paragraphs = map $1, dp.searchRecords();

    # Each record has:
    # - "text": The paragraph text content
    # - "style": The paragraph style (e.g., "Normal", "Heading1")
    @endcode

    @subsection WordDataProvider_reading_tables Reading Tables

    @code{.py}
    %requires WordDataProvider

    # Read table data from a document
    WordReadDataProvider dp("document.docx", {
        "content_type": "table",
        "table_index": 0,       # First table (0-based index)
        "header_row": True,     # First row contains headers
    });
    list<hash<auto>> rows = map $1, dp.searchRecords();

    # Read with explicit headers
    WordReadDataProvider dp2("document.docx", {
        "content_type": "table",
        "headers": ("Name", "Department", "Salary"),
    });
    @endcode

    @subsection WordDataProvider_reading_options Read Options

    - \c path: Path to the Word document
    - \c stream: Input stream for Word data
    - \c data: Binary Word document data
    - \c content_type: "paragraphs" (default) or "table"
    - \c table_index: Index of table to read (0-based, for table mode)
    - \c header_row: If \c True, first row of table contains headers
    - \c headers: List of header names to use

    @section WordDataProvider_writing Writing Word Documents

    @subsection WordDataProvider_writing_paragraphs Writing Paragraphs

    @code{.py}
    %requires WordDataProvider

    # Write paragraphs to a file
    WordWriteDataProvider dp("output.docx", {
        "content_type": "paragraphs",
        "title": "My Document",
    });

    dp.createRecord({"text": "First paragraph content", "style": "Normal"});
    dp.createRecord({"text": "Section Heading", "style": "Heading1"});
    dp.createRecord({"text": "More content here.", "style": "Normal"});

    dp.commit();  # Write the file
    @endcode

    @subsection WordDataProvider_writing_tables Writing Tables

    @code{.py}
    %requires WordDataProvider

    # Write table data to a file
    WordWriteDataProvider dp("output.docx", {
        "content_type": "table",
        "headers": ("Name", "Department", "Salary"),
        "title": "Employee Directory",
    });

    dp.createRecord({"Name": "Alice Smith", "Department": "Engineering", "Salary": "75000"});
    dp.createRecord({"Name": "Bob Johnson", "Department": "Marketing", "Salary": "65000"});

    dp.commit();  # Write the file
    @endcode

    @subsection WordDataProvider_writing_binary Writing to Binary

    @code{.py}
    %requires WordDataProvider

    # Create document in memory
    WordWriteDataProvider dp({
        "content_type": "paragraphs",
        "title": "In-Memory Document",
    });

    dp.createRecord({"text": "Some content"});

    # Get binary data instead of writing to file
    binary data = dp.getData();
    @endcode

    @subsection WordDataProvider_writing_options Write Options

    - \c path: Output file path
    - \c stream: Output stream
    - \c content_type: "paragraphs" (default) or "table"
    - \c headers: List of column headers (for table mode)
    - \c title: Optional document title (added as Heading1)

    @section WordDataProvider_styles Paragraph Styles

    When writing paragraphs, the following style names are supported:
    - \c "Normal": Regular paragraph text
    - \c "Heading1": Main heading (bold, 16pt)
    - \c "Heading2": Secondary heading (bold, 14pt)
    - \c "Heading3": Tertiary heading (bold, 12pt)

    @section WordDataProvider_errors Error Handling

    Common exceptions:
    - \c WORD-READ-OPTION-ERROR: Invalid read options or option conflicts
    - \c WORD-WRITE-OPTION-ERROR: Invalid write options or option conflicts

    @section WordDataProvider_relnotes Release Notes

    @subsection WordDataProvider_v1_0 WordDataProvider v1.0
    - initial release of the module
    - support for reading Word documents (.docx format)
    - support for writing Word documents (.docx format)
    - paragraph and table read/write modes
    - header row detection for tables
    - binary data input/output support
*/

#! contains all public definitions in the WordDataProvider module
public namespace WordDataProvider {
#! Application name
public const AppName = "Word";
}

namespace Priv {
#! Word logo
const WordLogo = File::readTextFile(get_script_dir() + "/word-logo.svg");
}
