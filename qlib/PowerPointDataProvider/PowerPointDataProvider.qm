# minimum required Qore version
%requires qore >= 1.0
%modern

# supports using the DataProvider module
%requires(reexport) DataProvider
%requires FileLocationHandler
%requires Util

%module-cmd(jni) add-relative-classpath ./jar/qore-dataprovider-powerpoint.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-full-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-compress-1.28.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-io-2.20.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-codec-1.19.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-lang3-3.18.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-math3-3.6.1.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/curvesapi-1.08.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/xmlbeans-5.3.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-collections4-4.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/log4j-api-2.24.3.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/SparseBitSet-1.3.jar

%module-cmd(jni) import org.qore.dataprovider.powerpoint.PowerPointIterator
%module-cmd(jni) import org.qore.dataprovider.powerpoint.PowerPointWriter

module PowerPointDataProvider {
    version = "1.0";
    desc = "user module providing a data provider API for reading and writing PowerPoint presentations";
    author = "David Nichols <david@qore.org>";
    url = "http://qore.org";
    license = "MIT";
    init = sub () {
        # register the data provider factories
        DataProvider::registerFactory(new PowerPointReadDataProviderFactory());
        DataProvider::registerFactory(new PowerPointWriteDataProviderFactory());

        # register the data provider application
        DataProviderActionCatalog::registerApp(<DataProviderAppInfo>{
            "name": PowerPointDataProvider::AppName,
            "display_name": "PowerPoint Presentations",
            "short_desc": "Read and write Microsoft PowerPoint presentations",
            "desc": "Read and write Microsoft PowerPoint presentations (.pptx format)",
            "groups": (DataProvider::AppGroup::Documents,),
            "logo": PowerPointLogo,
            "logo_file_name": "powerpoint-logo.svg",
            "logo_mime_type": MimeTypeSvg,
        });

        # register all supported actions
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": PowerPointDataProvider::AppName,
            "path": "/",
            "action": "read",
            "display_name": "Read PowerPoint Presentation File",
            "short_desc": "Read PowerPoint presentation from a specific file location",
            "desc": "Read PowerPoint presentation from a specific file location",
            "action_code": DPAT_FIND,
            "cls": "PowerPointDataProvider::PowerPointReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions{"content_type", "slide_index", "table_index",
                    "header_row"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions - ("path", "content_type", "slide_index", "table_index",
                    "header_row", "stream", "data"), {
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": PowerPointDataProvider::AppName,
            "path": "/",
            "action": "read-data",
            "display_name": "Read PowerPoint Presentation Inline Data",
            "short_desc": "Read PowerPoint presentation inline data",
            "desc": "Read PowerPoint presentation inline data",
            "action_code": DPAT_FIND,
            "cls": "PowerPointDataProvider::PowerPointReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions{"data",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions{"content_type", "slide_index", "table_index",
                    "header_row"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointReadDataProvider::ConstructorOptions - ("path", "content_type", "slide_index", "table_index",
                    "header_row", "stream", "data"), {
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": PowerPointDataProvider::AppName,
            "path": "/",
            "action": "write",
            "display_name": "Write PowerPoint Presentation File",
            "short_desc": "Write data to a PowerPoint presentation file",
            "desc": "Write data to a PowerPoint presentation file at a specified path",
            "action_code": DPAT_CREATE,
            "cls": "PowerPointDataProvider::PowerPointWriteDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointWriteDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointWriteDataProvider::ConstructorOptions{"content_type", "headers", "title"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": PowerPointDataProvider::AppName,
            "path": "/",
            "action": "write-data",
            "display_name": "Create PowerPoint Presentation Data",
            "short_desc": "Create PowerPoint presentation data and return as binary",
            "desc": "Create PowerPoint presentation data in memory and return it as binary data; useful for "
                "generating PowerPoint files without writing to disk",
            "action_code": DPAT_CREATE,
            "cls": "PowerPointDataProvider::PowerPointWriteDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                PowerPointWriteDataProvider::ConstructorOptions{"content_type", "headers", "title"}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });
    };
}

/** @mainpage PowerPointDataProvider Module

    @tableofcontents

    @section PowerPointDataProviderintro Introduction to the PowerPointDataProvider Module

    The %PowerPointDataProvider module provides a data provider API for reading and writing Microsoft PowerPoint
    presentations through the @ref dataproviderintro "DataProvider" API. It supports the modern .pptx format
    (PowerPoint 2007+) using Apache POI's XSLF library.

    The following classes are provided by this module:
    - @ref PowerPointDataProvider::PowerPointReadDataProvider "PowerPointReadDataProvider" - for reading presentations
    - @ref PowerPointDataProvider::PowerPointReadDataProviderFactory "PowerPointReadDataProviderFactory" - factory for read providers
    - @ref PowerPointDataProvider::PowerPointWriteDataProvider "PowerPointWriteDataProvider" - for writing presentations
    - @ref PowerPointDataProvider::PowerPointWriteDataProviderFactory "PowerPointWriteDataProviderFactory" - factory for write providers

    @section PowerPointDataProvider_reading Reading PowerPoint Presentations

    @subsection PowerPointDataProvider_reading_slides Reading Slides

    @code{.py}
    %requires PowerPointDataProvider

    # Read slides from a file path
    PowerPointReadDataProvider dp("presentation.pptx", {"content_type": "slides"});
    list<hash<auto>> slides = map $1, dp.searchRecords();

    # Each record has:
    # - "slide_number": The 1-based slide number
    # - "title": The slide title text
    # - "body": The slide body text (non-title text shapes)
    # - "notes": Speaker notes text
    # - "layout": The slide layout name
    @endcode

    @subsection PowerPointDataProvider_reading_tables Reading Tables

    @code{.py}
    %requires PowerPointDataProvider

    # Read table data from a slide
    PowerPointReadDataProvider dp("presentation.pptx", {
        "content_type": "table",
        "slide_index": 0,       # First slide (0-based)
        "table_index": 0,       # First table on the slide (0-based)
        "header_row": True,     # First row contains headers
    });
    list<hash<auto>> rows = map $1, dp.searchRecords();

    # Read with explicit headers
    PowerPointReadDataProvider dp2("presentation.pptx", {
        "content_type": "table",
        "headers": ("Name", "Department", "Salary"),
    });
    @endcode

    @subsection PowerPointDataProvider_reading_options Read Options

    - \c path: Path to the PowerPoint file
    - \c stream: Input stream for PowerPoint data
    - \c data: Binary PowerPoint data
    - \c content_type: "slides" (default) or "table"
    - \c slide_index: Index of slide for table mode (0-based)
    - \c table_index: Index of table on the slide (0-based, for table mode)
    - \c header_row: If \c True, first row of table contains headers
    - \c headers: List of header names to use

    @section PowerPointDataProvider_writing Writing PowerPoint Presentations

    @subsection PowerPointDataProvider_writing_slides Writing Slides

    @code{.py}
    %requires PowerPointDataProvider

    # Write slides to a file
    PowerPointWriteDataProvider dp("output.pptx", {
        "content_type": "slides",
        "title": "My Presentation",
    });

    dp.createRecord({"title": "Introduction", "body": "Welcome to the presentation"});
    dp.createRecord({"title": "Main Content", "body": "Here is the main content"});
    dp.createRecord({"title": "Conclusion", "body": "Thank you!", "notes": "Remember to summarize"});

    dp.commit();  # Write the file
    @endcode

    @subsection PowerPointDataProvider_writing_tables Writing Tables

    @code{.py}
    %requires PowerPointDataProvider

    # Write table data to a presentation
    PowerPointWriteDataProvider dp("output.pptx", {
        "content_type": "table",
        "headers": ("Name", "Department", "Salary"),
        "title": "Employee Directory",
    });

    dp.createRecord({"Name": "Alice Smith", "Department": "Engineering", "Salary": "75000"});
    dp.createRecord({"Name": "Bob Johnson", "Department": "Marketing", "Salary": "65000"});

    dp.commit();  # Write the file
    @endcode

    @subsection PowerPointDataProvider_writing_binary Writing to Binary

    @code{.py}
    %requires PowerPointDataProvider

    # Create presentation in memory
    PowerPointWriteDataProvider dp({
        "content_type": "slides",
    });

    dp.createRecord({"title": "Slide 1", "body": "Content"});

    # Get binary data instead of writing to file
    binary data = dp.getData();
    @endcode

    @subsection PowerPointDataProvider_writing_options Write Options

    - \c path: Output file path
    - \c stream: Output stream
    - \c content_type: "slides" (default) or "table"
    - \c headers: List of column headers (for table mode)
    - \c title: Optional presentation title

    @section PowerPointDataProvider_layouts Slide Layouts

    When writing slides, the following layout names are supported:
    - \c "TITLE_AND_CONTENT": Standard slide with title and content area (default)
    - \c "TITLE_ONLY": Slide with title only
    - \c "BLANK": Empty slide
    - \c "SECTION_HEADER": Section divider slide

    @section PowerPointDataProvider_errors Error Handling

    Common exceptions:
    - \c POWERPOINT-READ-OPTION-ERROR: Invalid read options or option conflicts
    - \c POWERPOINT-WRITE-OPTION-ERROR: Invalid write options or option conflicts

    @section PowerPointDataProvider_relnotes Release Notes

    @subsection PowerPointDataProvider_v1_0 PowerPointDataProvider v1.0
    - initial release of the module
    - support for reading PowerPoint presentations (.pptx format)
    - support for writing PowerPoint presentations (.pptx format)
    - slides and table read/write modes
    - speaker notes support
    - slide layout support
    - header row detection for tables
    - binary data input/output support
*/

#! contains all public definitions in the PowerPointDataProvider module
public namespace PowerPointDataProvider {
#! Application name
public const AppName = "PowerPoint";
}

namespace Priv {
#! PowerPoint logo
const PowerPointLogo = File::readTextFile(get_script_dir() + "/powerpoint-logo.svg");
}
