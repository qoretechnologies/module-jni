#! contains all public definitions in the OpcUaDataProvider module
public namespace OpcUaDataProvider {
#! Generic JSON Schema and OpenAPI projections for OPC UA schema snapshots
/** Builds Qorus-agnostic schema projections from the generic OPC UA schema snapshot contract. The
    generated artifacts are intended for API management, design-mode simulation, documentation, and
    stale-contract detection; they do not require a live OPC UA server and do not contain Qorus-specific
    metadata.
*/
public class OpcUaSchemaProjection {
    public {
        #! Projection contract version
        const ProjectionContractVersion = 1;

        #! JSON Schema projection artifact type
        const JsonSchemaArtifactType = "json-schema";

        #! OpenAPI projection artifact type
        const OpenApiArtifactType = "openapi";

        #! Projection mode for artifacts generated by this module
        const ProjectionMode = "qore-native";
    }

    #! Returns a stable content hash for the given schema snapshot
    /** @param snapshot OPC UA schema snapshot hash

        @return SHA-256 hash of a canonical Qore-native serialization of the snapshot
    */
    static string getSnapshotHash(hash<auto> snapshot) {
        return getCanonicalHashPayload(snapshot).toBinary().toSHA256();
    }

    #! Returns a stable content hash for a generated projection hash
    /** @param projection projection hash

        @return SHA-256 hash of a canonical Qore-native serialization of the projection
    */
    static string getProjectionHash(hash<auto> projection) {
        return getCanonicalHashPayload(projection).toBinary().toSHA256();
    }

    #! Builds a JSON Schema 2020-12 projection for an OPC UA schema snapshot
    /** @param snapshot OPC UA schema snapshot hash with \c namespaces and \c endpoints keys
        @param options optional projection options; supported keys include \c title, \c schema_id,
            \c service_name, and \c version

        @return JSON Schema projection as a Qore hash
        @throw OPCUA-SCHEMA-PROJECTION-ERROR if \a snapshot does not contain a list-valued \c endpoints key
    */
    static hash<auto> getJsonSchemaProjection(hash<auto> snapshot, *hash<auto> options) {
        checkSnapshot(snapshot);
        hash<auto> opts = options ?? {};
        string title = opts.title ?? opts.service_name ?? "OPC UA Service";
        string schema_id = opts.schema_id ?? sprintf("urn:qore:opcua:schema:%s", getSnapshotHash(snapshot));

        hash<auto> defs = {};
        hash<auto> endpoint_properties = {};
        list<string> endpoint_ids = ();
        foreach hash<auto> endpoint in (snapshot.endpoints) {
            *string endpoint_id = endpoint.endpoint_id;
            if (!endpoint_id) {
                continue;
            }

            string safe_id = getSafeIdentifier(endpoint_id);
            endpoint_ids += endpoint_id;
            endpoint_properties{endpoint_id} = {"$ref": sprintf("#/$defs/%s_endpoint", safe_id)};

            defs{sprintf("%s_endpoint", safe_id)} = getEndpointMetadataSchema(endpoint);
            string kind = endpoint.kind ?? "";
            if (kind =~ /^method/) {
                defs += getMethodSchemas(safe_id, endpoint);
            } else {
                defs += getVariableSchemas(safe_id, endpoint);
            }
        }

        return {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "$id": schema_id,
            "title": title,
            "description": "OPC UA schema projection generated from a generic schema snapshot",
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoints": {
                    "type": "object",
                    "additionalProperties": False,
                    "properties": endpoint_properties,
                    "required": endpoint_ids,
                },
            },
            "required": ("endpoints",),
            "$defs": defs,
            "x-opcua": getProjectionMetadata(snapshot, JsonSchemaArtifactType),
        };
    }

    #! Builds an OpenAPI 3.1 projection for an OPC UA schema snapshot
    /** @param snapshot OPC UA schema snapshot hash with \c namespaces and \c endpoints keys
        @param options optional projection options; supported keys include \c title, \c service_name,
            \c version, and \c base_path

        @return OpenAPI 3.1 projection as a Qore hash
        @throw OPCUA-SCHEMA-PROJECTION-ERROR if \a snapshot does not contain a list-valued \c endpoints key
    */
    static hash<auto> getOpenApiProjection(hash<auto> snapshot, *hash<auto> options) {
        checkSnapshot(snapshot);
        hash<auto> opts = options ?? {};
        string title = opts.title ?? opts.service_name ?? "OPC UA Service";
        string version = opts.version ?? "1.0.0";
        string base_path = normalizeBasePath(opts.base_path ?? "/opcua");

        hash<auto> json_schema = getJsonSchemaProjection(snapshot, options);
        hash<auto> components = {"schemas": json_schema{"$defs"}};
        hash<auto> paths = {};
        foreach hash<auto> endpoint in (snapshot.endpoints) {
            *string endpoint_id = endpoint.endpoint_id;
            if (!endpoint_id) {
                continue;
            }

            string safe_id = getSafeIdentifier(endpoint_id);
            string endpoint_path = sprintf("%s/endpoints/%s", base_path, escapePathSegment(endpoint_id));
            string kind = endpoint.kind ?? "";
            if (kind =~ /^method/) {
                paths{sprintf("%s/call", endpoint_path)} = {
                    "post": getOperation(endpoint, "call", sprintf("%s_call_request", safe_id),
                        sprintf("%s_call_result", safe_id)),
                };
                continue;
            }

            if (endpoint.readable ?? True) {
                paths{sprintf("%s/read", endpoint_path)} = {
                    "get": getOperation(endpoint, "read", NOTHING, sprintf("%s_read_result", safe_id)),
                };
            }
            if (endpoint.writable ?? endpoint.user_writable ?? False) {
                paths{sprintf("%s/write", endpoint_path)} = {
                    "post": getOperation(endpoint, "write", sprintf("%s_write_request", safe_id),
                        sprintf("%s_read_result", safe_id)),
                };
            }
            if (endpoint.historizing ?? False) {
                paths{sprintf("%s/history", endpoint_path)} = {
                    "get": getOperation(endpoint, "history-read", NOTHING,
                        sprintf("%s_history_read_result", safe_id)),
                };
            }
        }

        return {
            "openapi": "3.1.0",
            "info": {
                "title": title,
                "version": version,
                "description": "OPC UA API projection generated from a generic schema snapshot",
            },
            "paths": paths,
            "components": components,
            "x-opcua": getProjectionMetadata(snapshot, OpenApiArtifactType),
        };
    }

    #! Builds publishable schema projection artifacts for an OPC UA schema snapshot
    /** @param snapshot OPC UA schema snapshot hash with \c namespaces and \c endpoints keys
        @param options optional projection options; \c artifact_types can limit output to
            \c "json-schema" and/or \c "openapi"

        @return list of artifact hashes; each item contains \c type, \c content_type, \c projection_mode,
            \c snapshot_hash, \c hash, \c artifact_name, and \c content
        @throw OPCUA-SCHEMA-PROJECTION-ERROR if \a snapshot does not contain a list-valued \c endpoints key
    */
    static list<hash<auto>> getSchemaProjectionArtifacts(hash<auto> snapshot, *hash<auto> options) {
        checkSnapshot(snapshot);
        hash<auto> opts = options ?? {};
        list<string> artifact_types = normalizeArtifactTypes(opts.artifact_types);
        list<hash<auto>> rv = ();
        string snapshot_hash = getSnapshotHash(snapshot);
        string base_name = getArtifactBaseName(opts);

        if (inlist(JsonSchemaArtifactType, artifact_types)) {
            hash<auto> projection = getJsonSchemaProjection(snapshot, opts);
            rv += getArtifact(JsonSchemaArtifactType, "application/schema+json",
                sprintf("%s.schema.json", base_name), snapshot_hash, projection);
        }
        if (inlist(OpenApiArtifactType, artifact_types)) {
            hash<auto> projection = getOpenApiProjection(snapshot, opts);
            rv += getArtifact(OpenApiArtifactType, "application/vnd.oai.openapi+json",
                sprintf("%s.openapi.json", base_name), snapshot_hash, projection);
        }

        return rv;
    }

    private static checkSnapshot(hash<auto> snapshot) {
        if (snapshot.endpoints.typeCode() != NT_LIST) {
            throw "OPCUA-SCHEMA-PROJECTION-ERROR",
                "OPC UA schema snapshot must contain a list-valued `endpoints` key";
        }
    }

    private static hash<auto> getProjectionMetadata(hash<auto> snapshot, string projection_type) {
        return {
            "contract_version": snapshot.contract_version ?? 1,
            "projection_contract_version": ProjectionContractVersion,
            "projection": projection_type,
            "projection_mode": ProjectionMode,
            "source": snapshot.source ?? "unknown",
            "snapshot_hash": getSnapshotHash(snapshot),
            "namespaces": snapshot.namespaces ?? {},
        };
    }

    private static hash<auto> getArtifact(string type, string content_type, string artifact_name,
            string snapshot_hash, hash<auto> projection) {
        string projection_hash = getProjectionHash(projection);
        return {
            "type": type,
            "content_type": content_type,
            "artifact_name": artifact_name,
            "projection_mode": ProjectionMode,
            "snapshot_hash": snapshot_hash,
            "hash": projection_hash,
            "content": projection,
        };
    }

    private static string getCanonicalHashPayload(auto value) {
        int type_code = value.typeCode();
        switch (type_code) {
            case NT_HASH:
                hash<auto> h = value;
                list<string> parts = ();
                foreach string key in (sort(keys h)) {
                    parts += getCanonicalHashPayload(key)
                        + getCanonicalHashPayload(h{key});
                }
                return sprintf("h%d{%s}", parts.size(), parts.join(""));
            case NT_LIST:
                list<auto> l = value;
                return sprintf("l%d[%s]", l.size(),
                    (map getCanonicalHashPayload($1), l).join(""));
            case NT_STRING:
                string s = value.toString();
                return sprintf("s%d:%s", s.size(), s);
            case NT_BOOLEAN:
                return value ? "b1" : "b0";
            case NT_NOTHING:
                return "n";
            case NT_NULL:
                return "z";
            case NT_INT:
                return "i" + value.toString();
            case NT_FLOAT:
            case NT_NUMBER:
                return "d" + value.toString();
        }
        string fallback = value.toString();
        return sprintf("x%d:%d:%s", type_code, fallback.size(), fallback);
    }

    private static string getArtifactBaseName(hash<auto> options) {
        string base_name = options.artifact_name ?? options.service_name ?? options.title ?? "opcua-service";
        return getSafeIdentifier(base_name);
    }

    private static list<string> normalizeArtifactTypes(auto artifact_types) {
        if (!artifact_types) {
            return (JsonSchemaArtifactType, OpenApiArtifactType);
        }
        if (artifact_types.typeCode() == NT_STRING) {
            string value = artifact_types;
            checkArtifactType(value);
            return (value,);
        }
        if (artifact_types.typeCode() != NT_LIST) {
            throw "OPCUA-SCHEMA-PROJECTION-ERROR",
                sprintf("OPC UA schema projection `artifact_types` must be a string or list, got %y",
                    artifact_types.typeCode());
        }
        list<string> rv = ();
        foreach auto artifact_type in (artifact_types) {
            string value = artifact_type.toString();
            checkArtifactType(value);
            if (!inlist(value, rv)) {
                rv += value;
            }
        }
        return rv;
    }

    private static checkArtifactType(string value) {
        if (value != JsonSchemaArtifactType && value != OpenApiArtifactType) {
            throw "OPCUA-SCHEMA-PROJECTION-ERROR",
                sprintf("unsupported OPC UA schema projection artifact type %y; supported values are %y and %y",
                    value, JsonSchemaArtifactType, OpenApiArtifactType);
        }
    }

    private static string normalizeBasePath(string base_path) {
        if (!base_path) {
            return "/opcua";
        }
        if (base_path[0] != '/') {
            base_path = "/" + base_path;
        }
        if (base_path.size() > 1) {
            base_path =~ s/\/+$//;
        }
        return base_path;
    }

    private static string getSafeIdentifier(string value) {
        string rv = value;
        rv =~ s/[^A-Za-z0-9_]/_/g;
        rv =~ s/^_+//;
        rv =~ s/_+$//;
        if (!rv) {
            rv = "endpoint";
        }
        if (rv[0] =~ /[0-9]/) {
            rv = "e_" + rv;
        }
        return rv;
    }

    private static string getSafeOperationSuffix(string value) {
        string rv = getSafeIdentifier(value);
        rv =~ s/_+/_/g;
        return rv;
    }

    private static string escapePathSegment(string value) {
        string rv = value;
        rv =~ s/ /%20/g;
        rv =~ s/\//%2F/g;
        rv =~ s/\?/%3F/g;
        rv =~ s/#/%23/g;
        return rv;
    }

    private static hash<auto> getEndpointMetadataSchema(hash<auto> endpoint) {
        return {
            "type": "object",
            "additionalProperties": True,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "kind": {"const": endpoint.kind ?? "variable"},
                "node_id": {"type": "string"},
                "browse_name": {"type": "string"},
                "browse_path": {"type": "string"},
                "namespace_uri": {"type": "string"},
                "data_type": {"type": "string"},
                "value_rank": {"type": "integer"},
                "readable": {"type": "boolean"},
                "writable": {"type": "boolean"},
                "historizing": {"type": "boolean"},
            },
            "required": ("endpoint_id", "kind"),
            "x-opcua": getEndpointMetadata(endpoint),
        };
    }

    private static hash<auto> getEndpointMetadata(hash<auto> endpoint) {
        return {
            "endpoint_id": endpoint.endpoint_id,
            "kind": endpoint.kind ?? "variable",
            "node_id": endpoint.node_id,
            "object_node_id": endpoint.object_node_id,
            "browse_name": endpoint.browse_name,
            "browse_path": endpoint.browse_path,
            "namespace_uri": endpoint.namespace_uri,
            "data_type": endpoint.data_type,
            "value_rank": endpoint.value_rank,
            "array_dimensions": endpoint.array_dimensions,
            "directions": endpoint.directions,
        };
    }

    private static hash<auto> getVariableSchemas(string safe_id, hash<auto> endpoint) {
        hash<auto> defs = {};
        hash<auto> value_schema = getValueSchema(endpoint);
        defs{sprintf("%s_value", safe_id)} = value_schema;
        defs{sprintf("%s_read_result", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "value": {"$ref": sprintf("#/$defs/%s_value", safe_id)},
                "status": getStatusSchema(),
                "source_timestamp": getDateTimeSchema(),
                "server_timestamp": getDateTimeSchema(),
            },
            "required": ("endpoint_id", "value", "status"),
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": "read"},
        };
        defs{sprintf("%s_write_request", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "value": {"$ref": sprintf("#/$defs/%s_value", safe_id)},
            },
            "required": ("endpoint_id", "value"),
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": "write"},
        };
        defs{sprintf("%s_data_change_event", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "value": {"$ref": sprintf("#/$defs/%s_value", safe_id)},
                "source_timestamp": getDateTimeSchema(),
                "server_timestamp": getDateTimeSchema(),
                "status": getStatusSchema(),
            },
            "required": ("endpoint_id", "value", "status"),
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": "data-change"},
        };
        defs{sprintf("%s_server_read_callback", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "operation": {"const": "read"},
                "endpoint_id": {"const": endpoint.endpoint_id},
            },
            "required": ("operation", "endpoint_id"),
            "x-opcua": getEndpointMetadata(endpoint) + {"callback": True},
        };
        defs{sprintf("%s_server_write_callback", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "operation": {"const": "write"},
                "endpoint_id": {"const": endpoint.endpoint_id},
                "value": {"$ref": sprintf("#/$defs/%s_value", safe_id)},
            },
            "required": ("operation", "endpoint_id", "value"),
            "x-opcua": getEndpointMetadata(endpoint) + {"callback": True},
        };
        if (endpoint.historizing ?? False) {
            defs{sprintf("%s_history_read_result", safe_id)} = {
                "type": "object",
                "additionalProperties": False,
                "properties": {
                    "endpoint_id": {"const": endpoint.endpoint_id},
                    "values": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "additionalProperties": False,
                            "properties": {
                                "value": {"$ref": sprintf("#/$defs/%s_value", safe_id)},
                                "source_timestamp": getDateTimeSchema(),
                                "server_timestamp": getDateTimeSchema(),
                                "status": getStatusSchema(),
                            },
                            "required": ("value", "status"),
                        },
                    },
                    "status": getStatusSchema(),
                },
                "required": ("endpoint_id", "values", "status"),
                "x-opcua": getEndpointMetadata(endpoint) + {"operation": "history-read"},
            };
        }
        return defs;
    }

    private static hash<auto> getMethodSchemas(string safe_id, hash<auto> endpoint) {
        hash<auto> defs = {};
        hash<auto> input_schema = getArgumentsSchema(endpoint.input_arguments);
        hash<auto> output_schema = getArgumentsSchema(endpoint.output_arguments);
        defs{sprintf("%s_method_input", safe_id)} = input_schema;
        defs{sprintf("%s_method_output", safe_id)} = output_schema;
        defs{sprintf("%s_call_request", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "input_arguments": {"$ref": sprintf("#/$defs/%s_method_input", safe_id)},
            },
            "required": ("endpoint_id", "input_arguments"),
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": "call"},
        };
        defs{sprintf("%s_call_result", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "endpoint_id": {"const": endpoint.endpoint_id},
                "output_arguments": {"$ref": sprintf("#/$defs/%s_method_output", safe_id)},
                "status": getStatusSchema(),
            },
            "required": ("endpoint_id", "output_arguments", "status"),
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": "call-result"},
        };
        defs{sprintf("%s_server_call_callback", safe_id)} = {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "operation": {"const": "call"},
                "endpoint_id": {"const": endpoint.endpoint_id},
                "input_arguments": {"$ref": sprintf("#/$defs/%s_method_input", safe_id)},
            },
            "required": ("operation", "endpoint_id", "input_arguments"),
            "x-opcua": getEndpointMetadata(endpoint) + {"callback": True},
        };
        return defs;
    }

    private static hash<auto> getArgumentsSchema(auto arguments) {
        hash<auto> properties = {};
        list<string> required = ();
        if (arguments.typeCode() == NT_LIST) {
            foreach hash<auto> arg in (arguments) {
                string name = arg.name ?? sprintf("arg%d", required.size());
                properties{name} = getValueSchema(arg);
                if (arg.description) {
                    properties{name}.description = arg.description.toString();
                }
                required += name;
            }
        }
        return {
            "type": "object",
            "additionalProperties": False,
            "properties": properties,
            "required": required,
        };
    }

    private static hash<auto> getValueSchema(hash<auto> endpoint) {
        hash<auto> scalar = getScalarSchema(endpoint.data_type);
        if (endpoint.allowed_values.typeCode() == NT_LIST) {
            scalar{"enum"} = endpoint.allowed_values;
        } else if (endpoint.enum_values.typeCode() == NT_LIST) {
            scalar{"enum"} = map $1.value ?? $1.name ?? $1, endpoint.enum_values;
        }
        if (endpoint.fields.typeCode() == NT_LIST) {
            hash<auto> fields = {};
            list<string> required = ();
            foreach hash<auto> field in (endpoint.fields) {
                string field_name = field.name ?? sprintf("field%d", required.size());
                fields{field_name} = getValueSchema(field);
                required += field_name;
            }
            scalar = {
                "type": "object",
                "additionalProperties": False,
                "properties": fields,
                "required": required,
            };
        } else if (endpoint.structure_fields.typeCode() == NT_LIST) {
            hash<auto> structure_endpoint = endpoint + {"fields": endpoint.structure_fields};
            scalar = getValueSchema(structure_endpoint);
        }

        int value_rank = endpoint.value_rank ?? -1;
        if (value_rank >= 1) {
            return wrapArraySchema(scalar, value_rank, endpoint.array_dimensions);
        }
        return scalar;
    }

    private static hash<auto> wrapArraySchema(hash<auto> item_schema, int value_rank, auto array_dimensions) {
        hash<auto> rv = item_schema;
        for (int i = value_rank - 1; i >= 0; --i) {
            hash<auto> next = {
                "type": "array",
                "items": rv,
            };
            if (array_dimensions.typeCode() == NT_LIST && array_dimensions.size() > i
                    && array_dimensions[i].typeCode() == NT_INT && array_dimensions[i] > 0) {
                next.minItems = array_dimensions[i];
                next.maxItems = array_dimensions[i];
            }
            rv = next;
        }
        return rv;
    }

    private static hash<auto> getScalarSchema(auto data_type) {
        string dt = normalizeDataType(data_type);
        switch (dt) {
            case "boolean":
            case "bool":
                return {"type": "boolean", "x-opcua-data-type": data_type};

            case "sbyte":
            case "byte":
            case "int16":
            case "uint16":
            case "int32":
            case "uint32":
            case "int64":
            case "uint64":
            case "integer":
            case "i=2":
            case "i=3":
            case "i=4":
            case "i=5":
            case "i=6":
            case "i=7":
            case "i=8":
                return addIntegerBounds({"type": "integer", "x-opcua-data-type": data_type}, dt);

            case "float":
            case "double":
            case "number":
            case "i=10":
            case "i=11":
                return {"type": "number", "x-opcua-data-type": data_type};

            case "datetime":
            case "utctime":
            case "i=13":
                return getDateTimeSchema() + {"x-opcua-data-type": data_type};

            case "bytestring":
            case "i=15":
                return {"type": "string", "contentEncoding": "base64", "x-opcua-data-type": data_type};

            case "localizedtext":
            case "i=21":
                return {
                    "type": "object",
                    "additionalProperties": False,
                    "properties": {
                        "locale": {"type": "string"},
                        "text": {"type": "string"},
                    },
                    "required": ("text",),
                    "x-opcua-data-type": data_type,
                };

            case "qualifiedname":
            case "i=20":
                return {
                    "type": "object",
                    "additionalProperties": False,
                    "properties": {
                        "namespace_index": {"type": "integer", "minimum": 0},
                        "name": {"type": "string"},
                    },
                    "required": ("name",),
                    "x-opcua-data-type": data_type,
                };

            case "nodeid":
            case "expandednodeid":
            case "guid":
            case "xmlelement":
            case "statuscode":
            case "string":
            case "i=12":
            case "i=14":
            case "i=16":
            case "i=17":
            case "i=18":
            case "i=19":
                return {"type": "string", "x-opcua-data-type": data_type};
        }

        if (dt) {
            return {"x-opcua-data-type": data_type, "x-opcua-unresolved": True};
        }
        return {"x-opcua-unresolved": True};
    }

    private static hash<auto> addIntegerBounds(hash<auto> schema, string dt) {
        switch (dt) {
            case "sbyte":
            case "i=2":
                return schema + {"minimum": -128, "maximum": 127};
            case "byte":
            case "i=3":
                return schema + {"minimum": 0, "maximum": 255};
            case "int16":
            case "i=4":
                return schema + {"minimum": -32768, "maximum": 32767};
            case "uint16":
            case "i=5":
                return schema + {"minimum": 0, "maximum": 65535};
            case "uint32":
            case "i=7":
                return schema + {"minimum": 0, "maximum": 4294967295};
            case "uint64":
                return schema + {"minimum": 0};
        }
        return schema;
    }

    private static string normalizeDataType(auto data_type) {
        if (!data_type) {
            return "";
        }
        string dt = data_type.toString();
        dt =~ s/\s+//g;
        dt =~ s/^ns=0;//;
        dt =~ s/^BaseDataType$//;
        return tolower(dt);
    }

    private static hash<auto> getDateTimeSchema() {
        return {"type": "string", "format": "date-time"};
    }

    private static hash<auto> getStatusSchema() {
        return {
            "type": "object",
            "additionalProperties": False,
            "properties": {
                "code": {"type": "integer"},
                "symbolic_name": {"type": "string"},
                "severity": {"type": "string", "enum": ("Good", "Uncertain", "Bad")},
                "diagnostics": {"type": "string"},
            },
            "required": ("code", "symbolic_name", "severity"),
        };
    }

    private static hash<auto> getOperation(hash<auto> endpoint, string action, *string request_schema,
            string response_schema) {
        hash<auto> op = {
            "operationId": sprintf("opcua_%s_%s", getSafeOperationSuffix(endpoint.endpoint_id),
                getSafeOperationSuffix(action)),
            "summary": sprintf("OPC UA %s %s", action, endpoint.endpoint_id),
            "responses": {
                "200": {
                    "description": "Successful OPC UA operation",
                    "content": {
                        "application/json": {
                            "schema": {"$ref": sprintf("#/components/schemas/%s", response_schema)},
                        },
                    },
                },
            },
            "x-opcua": getEndpointMetadata(endpoint) + {"operation": action},
        };
        if (request_schema) {
            op.requestBody = {
                "required": True,
                "content": {
                    "application/json": {
                        "schema": {"$ref": sprintf("#/components/schemas/%s", request_schema)},
                    },
                },
            };
        }
        return op;
    }
}
}
