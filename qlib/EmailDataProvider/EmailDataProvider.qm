# minimum required Qore version
%requires qore >= 2.0
%modern

# supports using the DataProvider module
%requires(reexport) DataProvider
%requires FileLocationHandler
%requires Util

# Email-specific JARs
%module-cmd(jni) add-relative-classpath ./jar/qore-dataprovider-email.jar
%module-cmd(jni) add-relative-classpath ./jar/jakarta.mail-api-2.1.3.jar
%module-cmd(jni) add-relative-classpath ./jar/angus-mail-2.0.3.jar
%module-cmd(jni) add-relative-classpath ./jar/jakarta.activation-api-2.1.3.jar
%module-cmd(jni) add-relative-classpath ./jar/angus-activation-2.0.2.jar
%module-cmd(jni) add-relative-classpath ./jar/poi-scratchpad-5.5.0.jar

# POI JARs from ExcelDataProvider (needed for MsgIterator / HSMF)
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/poi-ooxml-full-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-compress-1.28.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-io-2.20.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-codec-1.19.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-lang3-3.18.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-math3-3.6.1.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/curvesapi-1.08.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/xmlbeans-5.3.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/commons-collections4-4.5.0.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/log4j-api-2.24.3.jar
%module-cmd(jni) add-relative-classpath ../ExcelDataProvider/jar/SparseBitSet-1.3.jar

%module-cmd(jni) import org.qore.dataprovider.email.EmlIterator
%module-cmd(jni) import org.qore.dataprovider.email.EmlWriter
%module-cmd(jni) import org.qore.dataprovider.email.MsgIterator
%module-cmd(jni) import org.qore.dataprovider.email.MboxIterator

module EmailDataProvider {
    version = "1.0";
    desc = "user module providing a data provider API for reading and writing email messages in EML, MSG, and MBOX formats";
    author = "David Nichols <david@qore.org>";
    url = "http://qore.org";
    license = "MIT";
    init = sub () {
        # register the data provider factories
        DataProvider::registerFactory(new EmlReadDataProviderFactory());
        DataProvider::registerFactory(new EmlWriteDataProviderFactory());
        DataProvider::registerFactory(new MsgReadDataProviderFactory());
        DataProvider::registerFactory(new MboxReadDataProviderFactory());

        # register the data provider application
        DataProviderActionCatalog::registerApp(<DataProviderAppInfo>{
            "name": EmailDataProvider::AppName,
            "display_name": "Email Messages",
            "short_desc": "Read and write email messages in EML, MSG, and MBOX formats",
            "desc": "Provides data provider support for reading and writing email messages in multiple "
                "formats:\n\n"
                "- **EML** (RFC 822 / MIME): Standard email format used by many email clients including "
                "Thunderbird, Apple Mail, and others. Each `.eml` file contains a single email message with "
                "headers, body text, HTML content, and attachments. Supports both reading and writing.\n\n"
                "- **MSG** (Microsoft Outlook): Proprietary binary format used by Microsoft Outlook. Each "
                "`.msg` file contains a single email message stored as an OLE2 Compound Document with MAPI "
                "properties. Read-only support.\n\n"
                "- **MBOX** (Unix Mailbox): Standard mailbox format where multiple email messages are "
                "concatenated in a single file, each delimited by a `From ` separator line. Used by "
                "Thunderbird, Evolution, and many Unix mail systems. Read-only support.\n\n"
                "All formats produce records with a unified schema including sender, recipients (To, CC, BCC), "
                "subject, date, plain text body, HTML body, attachments metadata, Message-ID, and In-Reply-To "
                "headers.",
            "groups": (DataProvider::AppGroup::Documents,),
            "logo": EmailLogo,
            "logo_file_name": "email-logo.svg",
            "logo_mime_type": MimeTypeSvg,
        });

        # register EML read action (from file)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "eml-read",
            "display_name": "Read EML Email File",
            "short_desc": "Read an EML email message from a file location",
            "desc": "Reads an EML (RFC 822 / MIME) email message from a file path and returns the message "
                "content as a structured record with sender, recipients, subject, date, body text, HTML "
                "content, attachments metadata, and message headers.\n\n"
                "EML is the standard email format supported by most email clients. Each file contains a "
                "single email message.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::EmlReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                EmlReadDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ),
        });

        # register EML read-data action (from inline data)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "eml-read-data",
            "display_name": "Read EML Email Inline Data",
            "short_desc": "Read an EML email message from inline binary data",
            "desc": "Reads an EML (RFC 822 / MIME) email message from inline binary data and returns the "
                "message content as a structured record.\n\n"
                "Use this action when the EML data is already available in memory rather than on disk.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::EmlReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                EmlReadDataProvider::ConstructorOptions{"data",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ),
        });

        # register MSG read action (from file)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "msg-read",
            "display_name": "Read MSG Email File",
            "short_desc": "Read a Microsoft Outlook MSG email from a file location",
            "desc": "Reads a Microsoft Outlook MSG email message from a file path and returns the message "
                "content as a structured record with sender, recipients, subject, date, body text, HTML "
                "content, attachments metadata, and message headers.\n\n"
                "MSG is the proprietary binary format used by Microsoft Outlook, stored as an OLE2 Compound "
                "Document with MAPI properties.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::MsgReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                MsgReadDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ),
        });

        # register MSG read-data action (from inline data)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "msg-read-data",
            "display_name": "Read MSG Email Inline Data",
            "short_desc": "Read a Microsoft Outlook MSG email from inline binary data",
            "desc": "Reads a Microsoft Outlook MSG email message from inline binary data and returns the "
                "message content as a structured record.\n\n"
                "Use this action when the MSG data is already available in memory rather than on disk.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::MsgReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                MsgReadDataProvider::ConstructorOptions{"data",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ),
        });

        # register MBOX read action (from file)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "mbox-read",
            "display_name": "Read MBOX Mailbox File",
            "short_desc": "Read email messages from an MBOX mailbox file",
            "desc": "Reads email messages from an MBOX (Unix Mailbox) file and returns each message as a "
                "structured record with sender, recipients, subject, date, body text, HTML content, "
                "attachments metadata, and message headers.\n\n"
                "MBOX files contain multiple email messages concatenated in a single file, each delimited "
                "by a `From ` separator line. This format is used by Thunderbird, Evolution, and many "
                "Unix mail systems.\n\n"
                "The `max_messages` option can be used to limit the number of messages read from the file.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::MboxReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                MboxReadDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                MboxReadDataProvider::ConstructorOptions{"max_messages",}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });

        # register MBOX read-data action (from inline data)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "mbox-read-data",
            "display_name": "Read MBOX Mailbox Inline Data",
            "short_desc": "Read email messages from inline MBOX data",
            "desc": "Reads email messages from inline MBOX (Unix Mailbox) binary data and returns each "
                "message as a structured record.\n\n"
                "Use this action when the MBOX data is already available in memory rather than on disk.\n\n"
                "The `max_messages` option can be used to limit the number of messages read from the data.",
            "action_code": DPAT_FIND,
            "cls": "EmailDataProvider::MboxReadDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                MboxReadDataProvider::ConstructorOptions{"data",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ) + DataProviderActionCatalog::getActionOptionFromFields(
                MboxReadDataProvider::ConstructorOptions{"max_messages",}, {
                    "preselected": True,
                    "loc": "constructor",
                }
            ),
        });

        # register EML write action (to file)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "eml-write",
            "display_name": "Write EML Email File",
            "short_desc": "Write an EML email message to a file location",
            "desc": "Writes an EML (RFC 822 / MIME) email message to a file path.\n\n"
                "Each record written represents a single email message with the following fields:\n"
                "- `from`: the sender's email address\n"
                "- `to`: list of To recipients\n"
                "- `cc`: list of CC recipients (optional)\n"
                "- `bcc`: list of BCC recipients (optional)\n"
                "- `subject`: the email subject line\n"
                "- `date`: the sent date (optional, defaults to current time)\n"
                "- `body_text`: plain text body content (optional)\n"
                "- `body_html`: HTML body content (optional)\n"
                "- `attachments`: list of attachment hashes with `name`, `content_type`, and `data` "
                "(optional)\n"
                "- `message_id`: the Message-ID header (optional)\n"
                "- `in_reply_to`: the In-Reply-To header (optional)\n"
                "- `reply_to`: the Reply-To header (optional)\n"
                "- `references`: the References header (optional)",
            "action_code": DPAT_CREATE,
            "cls": "EmailDataProvider::EmlWriteDataProvider",
            "options": DataProviderActionCatalog::getActionOptionFromFields(
                EmlWriteDataProvider::ConstructorOptions{"path",}, {
                    "preselected": True,
                    "required": True,
                    "loc": "constructor",
                }
            ),
        });

        # register EML write-data action (to binary data)
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": EmailDataProvider::AppName,
            "path": "/",
            "action": "eml-write-data",
            "display_name": "Create EML Email Data",
            "short_desc": "Create EML email data and return as binary",
            "desc": "Create EML (RFC 822 / MIME) email data in memory and return it as binary data; useful "
                "for generating EML files without writing to disk.\n\n"
                "Each record written represents a single email message with the standard email fields "
                "including `from`, `to`, `cc`, `bcc`, `subject`, `date`, `body_text`, `body_html`, "
                "`attachments`, `message_id`, `in_reply_to`, `reply_to`, and `references`.\n\n"
                "After writing all messages, use `getData()` to retrieve the binary EML data.",
            "action_code": DPAT_CREATE,
            "cls": "EmailDataProvider::EmlWriteDataProvider",
            "options": {},
        });
    };
}

/** @mainpage EmailDataProvider Module

    @tableofcontents

    @section EmailDataProviderintro Introduction to the EmailDataProvider Module

    The %EmailDataProvider module provides a data provider API for reading and writing email messages in
    multiple formats through the @ref dataproviderintro "DataProvider" API. It supports EML (RFC 822),
    MSG (Microsoft Outlook), and MBOX (Unix Mailbox) formats using Jakarta Mail and Apache POI HSMF libraries.

    The following classes are provided by this module:
    - @ref EmailDataProvider::EmlReadDataProvider "EmlReadDataProvider" - for reading EML files
    - @ref EmailDataProvider::EmlReadDataProviderFactory "EmlReadDataProviderFactory" - factory for EML read providers
    - @ref EmailDataProvider::EmlWriteDataProvider "EmlWriteDataProvider" - for writing EML files
    - @ref EmailDataProvider::EmlWriteDataProviderFactory "EmlWriteDataProviderFactory" - factory for EML write providers
    - @ref EmailDataProvider::MsgReadDataProvider "MsgReadDataProvider" - for reading MSG files
    - @ref EmailDataProvider::MsgReadDataProviderFactory "MsgReadDataProviderFactory" - factory for MSG read providers
    - @ref EmailDataProvider::MboxReadDataProvider "MboxReadDataProvider" - for reading MBOX files
    - @ref EmailDataProvider::MboxReadDataProviderFactory "MboxReadDataProviderFactory" - factory for MBOX read providers

    @section EmailDataProvider_reading Reading Email Messages

    @subsection EmailDataProvider_reading_eml Reading EML Files

    @code{.py}
    %requires EmailDataProvider

    # Read an EML file from a path
    EmlReadDataProvider dp({"path": "message.eml"});
    list<hash<auto>> records = map $1, dp.searchRecords();

    # Each record has: from, to, cc, bcc, subject, date, body_text, body_html,
    # attachments, message_id, in_reply_to
    @endcode

    @subsection EmailDataProvider_reading_msg Reading MSG Files

    @code{.py}
    %requires EmailDataProvider

    # Read a Microsoft Outlook MSG file
    MsgReadDataProvider dp({"path": "message.msg"});
    list<hash<auto>> records = map $1, dp.searchRecords();
    @endcode

    @subsection EmailDataProvider_reading_mbox Reading MBOX Files

    @code{.py}
    %requires EmailDataProvider

    # Read all messages from an MBOX file
    MboxReadDataProvider dp({"path": "mailbox.mbox"});
    list<hash<auto>> records = map $1, dp.searchRecords();

    # Read with a message limit
    MboxReadDataProvider dp2({"path": "mailbox.mbox", "max_messages": 100});
    @endcode

    @section EmailDataProvider_record_schema Record Schema

    All email data providers return records with the following fields:
    - \c from: The sender's email address (string)
    - \c to: List of To recipients (list of strings)
    - \c cc: List of CC recipients (optional list of strings)
    - \c bcc: List of BCC recipients (optional list of strings)
    - \c subject: The email subject line (string)
    - \c date: The sent date (optional date)
    - \c body_text: Plain text body content (optional string)
    - \c body_html: HTML body content (optional string)
    - \c attachments: List of attachment metadata hashes (optional), each with \c name, \c content_type, \c size, and \c data (binary content)
    - \c message_id: The Message-ID header value (optional string)
    - \c in_reply_to: The In-Reply-To header value (optional string)
    - \c reply_to: The Reply-To header value (optional string)
    - \c references: The References header value for threading (optional string)

    @section EmailDataProvider_writing Writing Email Messages

    @subsection EmailDataProvider_writing_eml Writing EML Files

    @code{.py}
    %requires EmailDataProvider

    # Write an EML file to a path
    EmlWriteDataProvider dp({"path": "message.eml"});

    dp.createRecord({
        "from": "sender@example.com",
        "to": ("recipient@example.com",),
        "subject": "Test Email",
        "body_text": "Hello, World!",
        "body_html": "<h1>Hello, World!</h1>",
    });

    dp.commit();
    @endcode

    @subsection EmailDataProvider_writing_binary Writing to Binary

    @code{.py}
    EmlWriteDataProvider dp();

    dp.createRecord({
        "from": "sender@example.com",
        "to": ("recipient@example.com",),
        "subject": "Test Email",
        "body_text": "Hello!",
    });

    # Get binary data instead of writing to file
    binary data = dp.getData();
    @endcode

    @section EmailDataProvider_errors Error Handling

    Common exceptions:
    - \c EML-READ-OPTION-ERROR: Invalid read options or option conflicts for EML provider
    - \c EML-WRITE-OPTION-ERROR: Invalid write options or option conflicts for EML provider
    - \c MSG-READ-OPTION-ERROR: Invalid read options or option conflicts for MSG provider
    - \c MBOX-READ-OPTION-ERROR: Invalid read options or option conflicts for MBOX provider

    @section EmailDataProvider_relnotes Release Notes

    @subsection EmailDataProvider_v1_0 EmailDataProvider v1.0
    - initial release of the module
    - support for reading EML (RFC 822 / MIME) email files
    - support for writing EML (RFC 822 / MIME) email files with text, HTML, and attachments
    - support for reading MSG (Microsoft Outlook) email files
    - support for reading MBOX (Unix Mailbox) files with multiple messages
    - unified record schema across all email formats
    - binary data and stream input/output support
*/

#! contains all public definitions in the EmailDataProvider module
public namespace EmailDataProvider {
#! Application name
public const AppName = "Email";

#! Returns the shared email record type used by all email data providers
/** @return a hash of field name to AbstractDataField entries describing the email record schema
*/
public hash<string, AbstractDataField> sub getEmailRecordType() {
    return {
        "from": new QoreDataField("from", "The sender's email address", AbstractDataProviderType::get(StringType)),
        "to": new QoreDataField("to", "List of To recipients",
            AbstractDataProviderType::get(new Type("list<string>"))),
        "cc": new QoreDataField("cc", "List of CC recipients (optional)",
            AbstractDataProviderType::get(new Type("*list<string>"))),
        "bcc": new QoreDataField("bcc", "List of BCC recipients (optional)",
            AbstractDataProviderType::get(new Type("*list<string>"))),
        "subject": new QoreDataField("subject", "The email subject line",
            AbstractDataProviderType::get(StringType)),
        "date": new QoreDataField("date", "The sent date of the email (optional)",
            AbstractDataProviderType::get(new Type("*date"))),
        "body_text": new QoreDataField("body_text", "Plain text body content (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
        "body_html": new QoreDataField("body_html", "HTML body content (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
        "attachments": new QoreDataField("attachments",
            "List of attachment metadata hashes with 'name', 'content_type', 'size', and 'data' (binary content) "
            "keys (optional)",
            AbstractDataProviderType::get(new Type("*list<hash<auto>>"))),
        "message_id": new QoreDataField("message_id", "The Message-ID header value (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
        "in_reply_to": new QoreDataField("in_reply_to", "The In-Reply-To header value (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
        "reply_to": new QoreDataField("reply_to", "The Reply-To header value (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
        "references": new QoreDataField("references", "The References header value for threading (optional)",
            AbstractDataProviderType::get(SoftStringOrNothingType)),
    };
}
}

namespace Priv {
#! Email logo
const EmailLogo = File::readTextFile(get_script_dir() + "/email-logo.svg");
}
