# minimum required Qore version
%requires qore >= 1.0
%modern

# import Camel and dependency JARs: must be added to the global classloader
# because Camel maintains long-lived routes and thread pools
%module-cmd(jni) global-add-relative-classpath ./jar/qore-dataprovider-camel.jar
%module-cmd(jni) global-add-relative-classpath ./jar/angus-activation-2.0.2.jar
%module-cmd(jni) global-add-relative-classpath ./jar/camel-api-4.8.0.jar
