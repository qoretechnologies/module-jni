%module-cmd(jni) import org.qore.dataprovider.camel.QoreCamelContext

# supports using the DataProvider module
%requires(reexport) DataProvider
# implements support for Camel connections
%requires(reexport) ConnectionProvider
%requires Util

module CamelDataProvider {
    version = "1.0";
    desc = "user module providing a data provider API for enterprise integration patterns "
        "via Apache Camel";
    author = "David Nichols <david@qore.org>";
    url = "http://qore.org";
    license = "MIT";
    init = sub () {
        # register connection schemes
        ConnectionSchemeCache::registerScheme("camel", CamelConnection::ConnectionScheme);

        # register the data provider factory
        DataProvider::registerFactory(new CamelDataProviderFactory());

        # register the data provider application
        DataProviderActionCatalog::registerApp(<DataProviderAppInfo>{
            "name": CamelDataProvider::AppName,
            "display_name": "Apache Camel",
            "short_desc": "Apache Camel enterprise integration patterns",
            "desc": "Apache Camel enterprise integration patterns",
            "groups": (DataProvider::AppGroup::Messaging,),
            "scheme": "camel",
            "logo": CamelLogo,
            "logo_file_name": "camel-logo.svg",
            "logo_mime_type": MimeTypeSvg,
        });

        # register all supported actions
        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": CamelDataProvider::AppName,
            "path": "/producer",
            "action": "send",
            "display_name": "Send Camel Message",
            "short_desc": "Send a message to a Camel endpoint",
            "desc": "Send a message to any Apache Camel endpoint URI",
            "action_code": DPAT_API,
        });

        DataProviderActionCatalog::registerAction(<DataProviderActionInfo>{
            "app": CamelDataProvider::AppName,
            "path": "/routes",
            "action": "routes",
            "display_name": "List Camel Routes",
            "short_desc": "List active Camel routes",
            "desc": "List all active routes in the Camel context",
            "action_code": DPAT_FIND,
        });
    };
}

/** @mainpage CamelDataProvider Module

    @tableofcontents

    @section cameldataproviderintro Introduction to the CamelDataProvider Module

    The %CamelDataProvider module provides a data provider API for enterprise integration
    patterns via Apache Camel.

    This data provider provides Apache Camel functionality with the \c camel factory and data
    provider with the same name, supporting message routing and endpoint integration
    (class @ref CamelDataProvider::CamelDataProvider "CamelDataProvider").

    @section cameldataprovider_examples Camel Data Provider Examples

    These examples are with \c qdp, the command-line interface to the Data Provider API.

    @par API Example: Send a Message
    @verbatim qdp 'camel/producer' request endpoint=direct:test body='hello world'
    @endverbatim

    @par API Example: List Routes
    @verbatim qdp 'camel/routes' search
    @endverbatim

    @section cameldataprovider_relnotes Release Notes

    @subsection cameldataprovider_v1_0 CamelDataProvider v1.0
    - initial release of the module
*/

#! Contains all public definitions in the CamelDataProvider module
public namespace CamelDataProvider {
#! Camel application name
public const AppName = "Camel";
}

namespace Priv {
#! Camel logo
const CamelLogo = File::readTextFile(get_script_dir() + "/camel-logo.svg");
}
