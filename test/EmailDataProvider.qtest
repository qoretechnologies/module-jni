%modern

%requires QUnit
%requires Util
%requires DataProvider
%requires jni

# Add classpaths BEFORE module load to share classloader context
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/qore-dataprovider-email.jar
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/jakarta.mail-api-2.1.3.jar
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/angus-mail-2.0.3.jar
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/jakarta.activation-api-2.1.3.jar
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/angus-activation-2.0.2.jar
%module-cmd(jni) add-relative-classpath ../qlib/EmailDataProvider/jar/poi-scratchpad-5.5.0.jar

# POI JARs (needed for MsgIterator / HSMF and EmailTestHelper)
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/poi-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/poi-ooxml-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/poi-ooxml-full-5.5.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-io-2.20.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-compress-1.28.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/xmlbeans-5.3.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-collections4-4.5.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-codec-1.19.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-lang3-3.18.0.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/commons-math3-3.6.1.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/SparseBitSet-1.3.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/log4j-api-2.24.3.jar
%module-cmd(jni) add-relative-classpath ../qlib/ExcelDataProvider/jar/curvesapi-1.08.jar

%module-cmd(jni) import org.qore.dataprovider.email.EmailTestHelper

%requires ../qlib/EmailDataProvider

%exec-class EmailDataProviderTest

public class EmailDataProviderTest inherits QUnit::Test {
    private {
        string test_data_dir;
    }

    constructor() : Test("EmailDataProviderTest", "1.0", \ARGV) {
        # Get absolute path for test data directory
        string script_dir = get_script_dir();
        if (script_dir == ".") {
            script_dir = getcwd();
        }
        test_data_dir = script_dir + "/email-test-data";

        addTestCase("test setup", \testSetup());
        addTestCase("EML: read plain text from path", \testEmlReadPlainTextPath());
        addTestCase("EML: read HTML email", \testEmlReadHtml());
        addTestCase("EML: read multipart with attachments", \testEmlReadMultipart());
        addTestCase("EML: read from stream", \testEmlReadStream());
        addTestCase("EML: read from binary data", \testEmlReadBinaryData());
        addTestCase("EML: record type fields", \testEmlRecordType());
        addTestCase("EML: factory tests", \testEmlFactory());
        addTestCase("MSG: read from path", \testMsgReadPath());
        addTestCase("MBOX: read multiple messages", \testMboxReadMultiple());
        addTestCase("MBOX: read from stream", \testMboxReadStream());
        addTestCase("MBOX: read from binary data", \testMboxReadBinaryData());
        addTestCase("MBOX: max_messages limit", \testMboxMaxMessages());
        addTestCase("MBOX: empty file", \testMboxEmpty());
        addTestCase("MBOX: factory tests", \testMboxFactory());
        addTestCase("factory: all factories registered", \testAllFactories());
        addTestCase("action registration", \testActionRegistration());
        addTestCase("negative: invalid EML path", \testNegativeInvalidEmlPath());
        addTestCase("negative: EML option conflicts", \testNegativeEmlOptionConflicts());
        addTestCase("negative: MSG option conflicts", \testNegativeMsgOptionConflicts());
        addTestCase("negative: MBOX option conflicts", \testNegativeMboxOptionConflicts());
        addTestCase("dummy provider: no input", \testDummyProvider());

        set_return_value(main());
    }

    testSetup() {
        # Create test data directory
        if (!is_dir(test_data_dir)) {
            mkdir(test_data_dir);
        }

        # Create test EML files
        EmailTestHelper::createSimpleEml(test_data_dir + "/simple.eml");
        EmailTestHelper::createHtmlEml(test_data_dir + "/html.eml");
        EmailTestHelper::createMultipartEml(test_data_dir + "/multipart.eml");

        # Create test MSG file using POI's POIFS API
        EmailTestHelper::createSimpleMsg(test_data_dir + "/simple.msg");

        # Create test MBOX files
        EmailTestHelper::createSimpleMbox(test_data_dir + "/three-messages.mbox");

        assertTrue(is_file(test_data_dir + "/simple.eml"), "simple.eml created");
        assertTrue(is_file(test_data_dir + "/simple.msg"), "simple.msg created");
        assertTrue(is_file(test_data_dir + "/three-messages.mbox"), "three-messages.mbox created");
    }

    testEmlReadPlainTextPath() {
        EmlReadDataProvider dp(test_data_dir + "/simple.eml");

        assertEq("EmlReadDataProvider", dp.getInfo().type);
        assertTrue(dp.getInfo().supports_read);
        assertTrue(dp.getInfo().has_record);

        # Read all records (should be exactly 1 for EML)
        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size(), "EML should yield exactly 1 record");

        hash<auto> rec = records[0];

        # Check required fields
        assertTrue(rec.hasKey("from"), "should have 'from' field");
        assertTrue(rec.hasKey("to"), "should have 'to' field");
        assertTrue(rec.hasKey("subject"), "should have 'subject' field");
        assertTrue(rec.hasKey("body_text"), "should have 'body_text' field");
        assertTrue(rec.hasKey("body_html"), "should have 'body_html' field");
        assertTrue(rec.hasKey("attachments"), "should have 'attachments' field");
        assertTrue(rec.hasKey("message_id"), "should have 'message_id' field");
        assertTrue(rec.hasKey("in_reply_to"), "should have 'in_reply_to' field");
        assertTrue(rec.hasKey("date"), "should have 'date' field");

        # Check content
        assertEq("Test Subject", rec.subject);
        assertTrue(rec.from.contains("sender@example.com"), "from should contain sender address");
        assertTrue(rec.body_text.contains("plain text test email"), "body should contain test text");
        # Message-ID is set by Jakarta Mail during saveChanges()
        assertTrue(exists rec.message_id, "should have a message_id");
    }

    testEmlReadHtml() {
        EmlReadDataProvider dp(test_data_dir + "/html.eml");
        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size());
        hash<auto> rec = records[0];

        assertEq("HTML Email Test", rec.subject);
        # Should have both text and HTML parts
        assertTrue(exists rec.body_text, "should have plain text body");
        assertTrue(exists rec.body_html, "should have HTML body");
        assertTrue(rec.body_html.contains("<h1>Hello</h1>"), "HTML body should contain heading");
    }

    testEmlReadMultipart() {
        EmlReadDataProvider dp(test_data_dir + "/multipart.eml");
        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size());
        hash<auto> rec = records[0];

        assertEq("Multipart Email Test", rec.subject);
        assertTrue(rec.from.contains("multipart-sender@example.com"), "from should contain sender");

        # Check CC recipient
        assertTrue(exists rec.cc, "should have CC recipients");
        assertTrue(rec.cc.size() >= 1, "should have at least 1 CC recipient");

        # Check body parts
        assertTrue(exists rec.body_text, "should have plain text body");
        assertTrue(exists rec.body_html, "should have HTML body");
        assertTrue(rec.body_html.contains("<b>HTML</b>"), "HTML body should contain bold text");

        # Check attachments
        assertTrue(exists rec.attachments, "should have attachments");
        assertTrue(rec.attachments.size() >= 1, "should have at least 1 attachment");
        assertEq("test-attachment.txt", rec.attachments[0].name);

        # Check In-Reply-To header
        assertEq("<original-001@example.com>", rec.in_reply_to);
    }

    testEmlReadStream() {
        FileInputStream fis(test_data_dir + "/simple.eml");
        EmlReadDataProvider dp(fis);

        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size());
        assertEq("Test Subject", records[0].subject);
    }

    testEmlReadBinaryData() {
        binary data = EmailTestHelper::createSimpleEmlBytes();

        EmlReadDataProvider dp({
            "data": data,
        });

        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size());
        assertEq("Test Subject", records[0].subject);
        assertTrue(records[0].body_text.contains("plain text test email"), "body should contain test text");
    }

    testEmlRecordType() {
        EmlReadDataProvider dp(test_data_dir + "/simple.eml");
        *hash<string, AbstractDataField> rt = dp.getRecordType();

        assertTrue(exists rt, "record type should not be empty");
        assertTrue(rt.hasKey("from"), "should have 'from' field");
        assertTrue(rt.hasKey("to"), "should have 'to' field");
        assertTrue(rt.hasKey("cc"), "should have 'cc' field");
        assertTrue(rt.hasKey("bcc"), "should have 'bcc' field");
        assertTrue(rt.hasKey("subject"), "should have 'subject' field");
        assertTrue(rt.hasKey("date"), "should have 'date' field");
        assertTrue(rt.hasKey("body_text"), "should have 'body_text' field");
        assertTrue(rt.hasKey("body_html"), "should have 'body_html' field");
        assertTrue(rt.hasKey("attachments"), "should have 'attachments' field");
        assertTrue(rt.hasKey("message_id"), "should have 'message_id' field");
        assertTrue(rt.hasKey("in_reply_to"), "should have 'in_reply_to' field");
    }

    testEmlFactory() {
        EmlReadDataProviderFactory factory();

        assertEq("emlread", factory.getInfo().name);

        # Create provider via factory
        AbstractDataProvider dp = factory.create({
            "path": test_data_dir + "/simple.eml",
        });

        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(1, records.size());
        assertEq("Test Subject", records[0].subject);
    }

    testMsgReadPath() {
        MsgReadDataProvider dp(test_data_dir + "/simple.msg");

        assertEq("MsgReadDataProvider", dp.getInfo().type);
        assertTrue(dp.getInfo().supports_read);
        assertTrue(dp.getInfo().has_record);

        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(1, records.size(), "MSG should yield exactly 1 record");
        hash<auto> rec = records[0];

        # Check required fields exist
        assertTrue(rec.hasKey("from"), "should have 'from' field");
        assertTrue(rec.hasKey("to"), "should have 'to' field");
        assertTrue(rec.hasKey("subject"), "should have 'subject' field");

        # Check content from our test MSG file
        assertEq("Test MSG Subject", rec.subject);
        assertTrue(rec.from.contains("Test Sender"), "from should contain 'Test Sender'");
    }

    testMboxReadMultiple() {
        MboxReadDataProvider dp(test_data_dir + "/three-messages.mbox");

        assertEq("MboxReadDataProvider", dp.getInfo().type);
        assertTrue(dp.getInfo().supports_read);
        assertTrue(dp.getInfo().has_record);

        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(3, records.size(), "MBOX should yield 3 messages");

        # Check subjects
        assertEq("First Message", records[0].subject);
        assertEq("Second Message", records[1].subject);
        assertEq("Third Message", records[2].subject);

        # Check senders
        assertTrue(records[0].from.contains("sender1@example.com"), "first message from sender1");
        assertTrue(records[1].from.contains("sender2@example.com"), "second message from sender2");
        assertTrue(records[2].from.contains("sender3@example.com"), "third message from sender3");

        # Check bodies
        assertTrue(records[0].body_text.contains("first message"), "first message body");
        assertTrue(records[1].body_text.contains("second message"), "second message body");
        assertTrue(records[2].body_text.contains("third message"), "third message body");
    }

    testMboxReadStream() {
        FileInputStream fis(test_data_dir + "/three-messages.mbox");
        MboxReadDataProvider dp(fis);

        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(3, records.size(), "MBOX stream should yield 3 messages");
        assertEq("First Message", records[0].subject);
    }

    testMboxReadBinaryData() {
        binary data = EmailTestHelper::createSimpleMboxBytes();

        MboxReadDataProvider dp({
            "data": data,
        });

        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(3, records.size(), "MBOX binary data should yield 3 messages");
        assertEq("First Message", records[0].subject);
    }

    testMboxMaxMessages() {
        MboxReadDataProvider dp({
            "path": test_data_dir + "/three-messages.mbox",
            "max_messages": 2,
        });

        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(2, records.size(), "should only read 2 of 3 messages");
        assertEq("First Message", records[0].subject);
        assertEq("Second Message", records[1].subject);
    }

    testMboxEmpty() {
        # Create an empty mbox file
        string empty_path = test_data_dir + "/empty.mbox";
        {
            File f();
            f.open2(empty_path, O_CREAT | O_WRONLY | O_TRUNC);
        }

        MboxReadDataProvider dp(empty_path);
        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(0, records.size(), "empty MBOX should yield 0 records");
    }

    testMboxFactory() {
        MboxReadDataProviderFactory factory();

        assertEq("mboxread", factory.getInfo().name);

        AbstractDataProvider dp = factory.create({
            "path": test_data_dir + "/three-messages.mbox",
        });

        list<hash<auto>> records = map $1, dp.searchRecords();
        assertEq(3, records.size());
    }

    testAllFactories() {
        # Verify all 3 factories are registered
        EmlReadDataProviderFactory eml_factory();
        assertEq("emlread", eml_factory.getInfo().name);

        MsgReadDataProviderFactory msg_factory();
        assertEq("msgread", msg_factory.getInfo().name);

        MboxReadDataProviderFactory mbox_factory();
        assertEq("mboxread", mbox_factory.getInfo().name);
    }

    testActionRegistration() {
        # Verify that actions are properly registered
        *list<hash<DataProviderActionInfo>> actions = DataProviderActionCatalog::getActions("Email");
        assertTrue(exists actions, "should have actions registered for Email app");
        assertTrue(actions.size() >= 6, "should have at least 6 actions");

        # Create a lookup hash for easier testing
        hash<string, hash<DataProviderActionInfo>> action_map;
        foreach hash<DataProviderActionInfo> action in (actions) {
            action_map{action.action} = action;
        }

        # Verify EML actions
        assertTrue(action_map.hasKey("eml-read"), "should have 'eml-read' action");
        assertEq("Read EML Email File", action_map."eml-read".display_name);
        assertTrue(action_map."eml-read".options.hasKey("path"), "eml-read should have 'path' option");

        assertTrue(action_map.hasKey("eml-read-data"), "should have 'eml-read-data' action");
        assertEq("Read EML Email Inline Data", action_map."eml-read-data".display_name);
        assertTrue(action_map."eml-read-data".options.hasKey("data"), "eml-read-data should have 'data' option");

        # Verify MSG actions
        assertTrue(action_map.hasKey("msg-read"), "should have 'msg-read' action");
        assertEq("Read MSG Email File", action_map."msg-read".display_name);
        assertTrue(action_map."msg-read".options.hasKey("path"), "msg-read should have 'path' option");

        assertTrue(action_map.hasKey("msg-read-data"), "should have 'msg-read-data' action");
        assertEq("Read MSG Email Inline Data", action_map."msg-read-data".display_name);
        assertTrue(action_map."msg-read-data".options.hasKey("data"), "msg-read-data should have 'data' option");

        # Verify MBOX actions
        assertTrue(action_map.hasKey("mbox-read"), "should have 'mbox-read' action");
        assertEq("Read MBOX Mailbox File", action_map."mbox-read".display_name);
        assertTrue(action_map."mbox-read".options.hasKey("path"), "mbox-read should have 'path' option");
        assertTrue(action_map."mbox-read".options.hasKey("max_messages"),
            "mbox-read should have 'max_messages' option");

        assertTrue(action_map.hasKey("mbox-read-data"), "should have 'mbox-read-data' action");
        assertEq("Read MBOX Mailbox Inline Data", action_map."mbox-read-data".display_name);
        assertTrue(action_map."mbox-read-data".options.hasKey("data"), "mbox-read-data should have 'data' option");
        assertTrue(action_map."mbox-read-data".options.hasKey("max_messages"),
            "mbox-read-data should have 'max_messages' option");
    }

    testNegativeInvalidEmlPath() {
        bool threw = False;
        try {
            EmlReadDataProvider dp("/nonexistent/path/to/file.eml");
            dp.searchRecords();
        } catch (hash<ExceptionInfo> ex) {
            threw = True;
        }
        assertTrue(threw, "should throw exception for invalid EML path");
    }

    testNegativeEmlOptionConflicts() {
        # Test path and stream conflict
        assertThrows("EML-READ-OPTION-ERROR", sub () {
            FileInputStream fis(test_data_dir + "/simple.eml");
            EmlReadDataProvider dp({
                "path": test_data_dir + "/simple.eml",
                "stream": fis,
            });
        });

        # Test path and data conflict
        assertThrows("EML-READ-OPTION-ERROR", sub () {
            EmlReadDataProvider dp({
                "path": test_data_dir + "/simple.eml",
                "data": <abcd>,
            });
        });

        # Test stream and data conflict
        assertThrows("EML-READ-OPTION-ERROR", sub () {
            FileInputStream fis(test_data_dir + "/simple.eml");
            EmlReadDataProvider dp({
                "stream": fis,
                "data": <abcd>,
            });
        });
    }

    testNegativeMsgOptionConflicts() {
        # Test path and stream conflict
        assertThrows("MSG-READ-OPTION-ERROR", sub () {
            FileInputStream fis(test_data_dir + "/simple.msg");
            MsgReadDataProvider dp({
                "path": test_data_dir + "/simple.msg",
                "stream": fis,
            });
        });

        # Test path and data conflict
        assertThrows("MSG-READ-OPTION-ERROR", sub () {
            MsgReadDataProvider dp({
                "path": test_data_dir + "/simple.msg",
                "data": <abcd>,
            });
        });
    }

    testNegativeMboxOptionConflicts() {
        # Test path and stream conflict
        assertThrows("MBOX-READ-OPTION-ERROR", sub () {
            FileInputStream fis(test_data_dir + "/three-messages.mbox");
            MboxReadDataProvider dp({
                "path": test_data_dir + "/three-messages.mbox",
                "stream": fis,
            });
        });

        # Test path and data conflict
        assertThrows("MBOX-READ-OPTION-ERROR", sub () {
            MboxReadDataProvider dp({
                "path": test_data_dir + "/three-messages.mbox",
                "data": <abcd>,
            });
        });
    }

    testDummyProvider() {
        # Create providers with no input (dummy mode)
        EmlReadDataProvider eml_dp();
        assertEq("eml", eml_dp.getName());
        *hash<string, AbstractDataField> eml_rt = eml_dp.getRecordType();
        assertEq(0, eml_rt.size(), "dummy EML provider should have empty record type");

        MsgReadDataProvider msg_dp();
        assertEq("msg", msg_dp.getName());
        *hash<string, AbstractDataField> msg_rt = msg_dp.getRecordType();
        assertEq(0, msg_rt.size(), "dummy MSG provider should have empty record type");

        MboxReadDataProvider mbox_dp();
        assertEq("mbox", mbox_dp.getName());
        *hash<string, AbstractDataField> mbox_rt = mbox_dp.getRecordType();
        assertEq(0, mbox_rt.size(), "dummy MBOX provider should have empty record type");
    }
}
