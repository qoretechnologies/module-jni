%modern

%requires QUnit
%requires Util
%requires DataProvider
%requires ConnectionProvider
%requires jni
%requires ../qlib/JdbcDataProvider

%exec-class JdbcDataProviderTest

public class JdbcDataProviderTest inherits QUnit::Test {
    private {
        *string jdbc_url;
        *string jdbc_user;
        *string jdbc_password;
        *string jdbc_classpath;
        *string jdbc_driver_class;
    }

    constructor() : Test("JdbcDataProviderTest", "1.0", \ARGV) {
        # Get JDBC connection from environment
        jdbc_url = ENV.QORE_DB_CONNSTR_JDBC_PGSQL;
        jdbc_user = ENV.JDBC_DB_USER ?? "postgres";
        jdbc_password = ENV.JDBC_DB_PASSWORD ?? "omq";
        jdbc_classpath = ENV.JDBC_DB_CLASSPATH;
        jdbc_driver_class = ENV.JDBC_DB_DRIVER_CLASS;

        addTestCase("factory test", \testFactory());
        addTestCase("action registration", \testActionRegistration());
        addTestCase("negative: missing url", \testNegativeMissingUrl());
        addTestCase("negative: missing user", \testNegativeMissingUser());
        addTestCase("child providers", \testChildProviders());
        addTestCase("query provider", \testQueryProvider());
        addTestCase("tables provider", \testTablesProvider());

        set_return_value(main());
    }

    private testFactory() {
        JdbcDataProviderFactory factory();
        assertEq("jdbc-dp", factory.getInfo().name);
    }

    private testActionRegistration() {
        assertEq(True, DataProviderActionCatalog::getApp("JdbcDP").val());
    }

    private testNegativeMissingUrl() {
        assertThrows("JDBC-CONSTRUCTOR-ERROR", sub () {
            new JdbcDataProvider({
                "user": "test",
                "password": "test",
            });
        });
    }

    private testNegativeMissingUser() {
        assertThrows("JDBC-CONSTRUCTOR-ERROR", sub () {
            new JdbcDataProvider({
                "url": "jdbc:postgresql://localhost/test",
            });
        });
    }

    private testChildProviders() {
        if (!jdbc_url) {
            testSkip("no JDBC connection available (QORE_DB_CONNSTR_JDBC_PGSQL not set)");
        }
        JdbcDataProvider dp(getJdbcOptions());
        list<string> children = dp.getChildProviderNames();
        assertTrue(children.size() >= 3);
        assertTrue(inlist("tables", children));
        assertTrue(inlist("query", children));
        assertTrue(inlist("exec", children));
    }

    private testQueryProvider() {
        if (!jdbc_url) {
            testSkip("no JDBC connection available (QORE_DB_CONNSTR_JDBC_PGSQL not set)");
        }
        JdbcDataProvider dp(getJdbcOptions());

        # Create a test table
        AbstractDataProvider execDp = dp.getChildProvider("exec");
        execDp.doRequest({"sql": "CREATE TABLE IF NOT EXISTS jdbc_dp_test (id SERIAL PRIMARY KEY, name VARCHAR(100), value INT)"});

        on_exit {
            execDp.doRequest({"sql": "DROP TABLE IF EXISTS jdbc_dp_test"});
        }

        # Insert data
        execDp.doRequest({"sql": "INSERT INTO jdbc_dp_test (name, value) VALUES ('alpha', 1)"});
        execDp.doRequest({"sql": "INSERT INTO jdbc_dp_test (name, value) VALUES ('beta', 2)"});

        # Query data
        AbstractDataProvider queryDp = dp.getChildProvider("query");
        auto result = queryDp.doRequest({"sql": "SELECT name, value FROM jdbc_dp_test ORDER BY value"});
        assertTrue(result instanceof hash);
        assertGt(0, result.rows.size());
        assertEq(2, result.row_count);
    }

    private testTablesProvider() {
        if (!jdbc_url) {
            testSkip("no JDBC connection available (QORE_DB_CONNSTR_JDBC_PGSQL not set)");
        }
        JdbcDataProvider dp(getJdbcOptions());

        AbstractDataProvider tablesDp = dp.getChildProvider("tables");
        list<hash<auto>> tables = map $1, tablesDp.searchRecords();
        # PostgreSQL always has system tables
        assertTrue(tables.size() >= 0);
    }

    private hash<auto> getJdbcOptions() {
        hash<auto> rv = {
            "url": jdbc_url,
            "user": jdbc_user,
            "password": jdbc_password,
        };
        if (jdbc_classpath) {
            rv.classpath = jdbc_classpath;
        }
        if (jdbc_driver_class) {
            rv.driver_class = jdbc_driver_class;
        }
        return rv;
    }
}
