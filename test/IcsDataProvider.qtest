        assertEq("Roundtrip Todo", t.summary);
        assertTrue(t.dtstart instanceof date, "dtstart should be a date");
        assertTrue(t.due instanceof date, "due should be a date");
        assertTrue(t.completed instanceof date, "completed should be a date");
        assertEq(100, t.percent_complete);
        assertEq(3, t.priority);
        assertEq("COMPLETED", t.status);
        assertEq("Full roundtrip todo with all fields", t.description);
        assertEq("boss@example.com", t.organizer);
        assertTrue(t.attendees instanceof list, "attendees should be a list");
        assertEq(2, t.attendees.size(), "should have 2 attendees");
        assertTrue(t.categories instanceof list, "categories should be a list");
        assertEq(2, t.categories.size(), "should have 2 categories");
        assertTrue(inlist("WORK", t.categories), "should have WORK category");
        assertTrue(inlist("PROJECT", t.categories), "should have PROJECT category");
        assertEq("CONFIDENTIAL", t.classification);
        assertEq("https://example.com/todos/rt-001", t.url);
        assertTrue(t.created instanceof date, "created should be a date");
        assertTrue(t.last_modified instanceof date, "last_modified should be a date");
        assertEq(4, t.sequence);
        assertTrue(t.alarms instanceof list, "alarms should be a list");
        assertEq(1, t.alarms.size(), "should have 1 alarm");
        assertEq("DISPLAY", t.alarms[0].action);
        assertEq("-PT30M", t.alarms[0].trigger);
        assertEq("Todo due soon", t.alarms[0].description);
    }

    testContentTypeDefault() {
        # Verify default content_type is "events" - reading the todo ICS file without
        # specifying content_type should return no records (events mode skips VTODOs)
        IcsReadDataProvider dp_events(test_data_dir + "/todos.ics");
        list<hash<auto>> event_records = map $1, dp_events.searchRecords();
        assertEq(0, event_records.size(), "default content_type should be events, no events in todos file");

        # Verify reading events file with todos content_type returns no records
        IcsReadDataProvider dp_todos(test_data_dir + "/simple.ics", {
            "content_type": "todos",
        });
        list<hash<auto>> todo_records = map $1, dp_todos.searchRecords();
        assertEq(0, todo_records.size(), "todos content_type on events file should return no records");

        # Verify events file without specifying content_type returns events
        IcsReadDataProvider dp_default(test_data_dir + "/simple.ics");
        list<hash<auto>> default_records = map $1, dp_default.searchRecords();
        assertEq(3, default_records.size(), "default content_type should read events");
    }
