    testTodoReadPath() {
        IcsReadDataProvider dp(test_data_dir + "/todos.ics", {
            "content_type": "todos",
        });

        list<hash<auto>> records = map $1, dp.searchRecords();

        assertEq(3, records.size(), "should have 3 todos");

        # Todo 1: Complete project proposal
        hash<auto> t1 = records[0];
        assertEq("todo-001@test.example.com", t1.uid);
        assertEq("Complete project proposal", t1.summary);
        assertTrue(t1.due instanceof date, "due should be a date");
        assertEq(1, t1.priority);
        assertEq(75, t1.percent_complete);
        assertEq("IN-PROCESS", t1.status);
        assertEq("Write and submit the Q2 project proposal", t1.description);
        assertEq("manager@example.com", t1.organizer);
        assertTrue(t1.categories instanceof list, "categories should be a list");
        assertEq(2, t1.categories.size(), "should have 2 categories");
        assertTrue(inlist("WORK", t1.categories), "should have WORK category");
        assertTrue(inlist("URGENT", t1.categories), "should have URGENT category");
        assertEq("PRIVATE", t1.classification);
        assertEq("https://example.com/projects/proposal", t1.url);
        assertTrue(t1.created instanceof date, "created should be a date");
        assertTrue(t1.last_modified instanceof date, "last_modified should be a date");
        assertEq(2, t1.sequence);
        assertTrue(t1.alarms instanceof list, "alarms should be a list");
        assertEq(1, t1.alarms.size(), "should have 1 alarm");
        assertEq("DISPLAY", t1.alarms[0].action);
        assertEq("-P1D", t1.alarms[0].trigger);
        assertEq("Proposal due tomorrow", t1.alarms[0].description);

        # Todo 2: Buy groceries
        hash<auto> t2 = records[1];
        assertEq("todo-002@test.example.com", t2.uid);
        assertEq("Buy groceries", t2.summary);
        assertTrue(t2.due instanceof date, "due should be a date for todo 2");
        assertEq(5, t2.priority);
        assertEq("NEEDS-ACTION", t2.status);

        # Todo 3: Review code - completed
        hash<auto> t3 = records[2];
        assertEq("todo-003@test.example.com", t3.uid);
        assertEq("Review code", t3.summary);
        assertTrue(t3.completed instanceof date, "completed should be a date");
        assertEq(100, t3.percent_complete);
        assertEq("COMPLETED", t3.status);
        assertEq("Review pull request #42", t3.description);
    }

