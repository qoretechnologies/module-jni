    testTodoRecordType() {
        IcsReadDataProvider dp(test_data_dir + "/todos.ics", {
            "content_type": "todos",
        });

        *hash<string, AbstractDataField> fields = dp.getRecordType();
        assertTrue(exists fields, "should have record type for todos");

        # Verify todo-specific fields are present
        assertTrue(fields.hasKey("due"), "should have 'due' field");
        assertTrue(fields.hasKey("completed"), "should have 'completed' field");
        assertTrue(fields.hasKey("percent_complete"), "should have 'percent_complete' field");
        assertTrue(fields.hasKey("priority"), "should have 'priority' field");

        # Verify shared fields are present
        assertTrue(fields.hasKey("uid"), "should have 'uid' field");
        assertTrue(fields.hasKey("summary"), "should have 'summary' field");
        assertTrue(fields.hasKey("dtstart"), "should have 'dtstart' field");
        assertTrue(fields.hasKey("status"), "should have 'status' field");
        assertTrue(fields.hasKey("description"), "should have 'description' field");
        assertTrue(fields.hasKey("organizer"), "should have 'organizer' field");
        assertTrue(fields.hasKey("attendees"), "should have 'attendees' field");
        assertTrue(fields.hasKey("rrule"), "should have 'rrule' field");
        assertTrue(fields.hasKey("categories"), "should have 'categories' field");
        assertTrue(fields.hasKey("classification"), "should have 'classification' field");
        assertTrue(fields.hasKey("url"), "should have 'url' field");
        assertTrue(fields.hasKey("created"), "should have 'created' field");
        assertTrue(fields.hasKey("last_modified"), "should have 'last_modified' field");
        assertTrue(fields.hasKey("sequence"), "should have 'sequence' field");
        assertTrue(fields.hasKey("alarms"), "should have 'alarms' field");

        # Verify event-specific fields are NOT present
        assertFalse(fields.hasKey("dtend"), "should NOT have 'dtend' field for todos");
        assertFalse(fields.hasKey("duration"), "should NOT have 'duration' field for todos");
        assertFalse(fields.hasKey("location"), "should NOT have 'location' field for todos");
        assertFalse(fields.hasKey("transp"), "should NOT have 'transp' field for todos");

        # Total fields: uid, summary, dtstart, due, completed, percent_complete, priority,
        # status, description, organizer, attendees, rrule, categories, classification,
        # url, created, last_modified, sequence, alarms = 19
        assertEq(19, fields.size(), "should have 19 total todo fields");
    }

    testTodoWriteBasic() {
        string output_path = test_data_dir + "/write-todo-test.ics";
        on_exit {
            if (is_file(output_path)) {
                unlink(output_path);
            }
        }

        {
            IcsWriteDataProvider dp(output_path, {
                "content_type": "todos",
            });

            dp.createRecord({
                "uid": "write-todo-001@test.com",
                "summary": "Written Todo 1",
                "due": 2026-04-15T17:00:00Z,
                "priority": 2,
                "percent_complete": 50,
                "status": "IN-PROCESS",
            });
            dp.createRecord({
                "uid": "write-todo-002@test.com",
                "summary": "Written Todo 2",
                "due": 2026-04-20T12:00:00Z,
                "status": "NEEDS-ACTION",
            });

            dp.commit();
        }

        assertTrue(is_file(output_path), "todo output file should exist");

        # Read back and verify
        IcsReadDataProvider rdp(output_path, {
            "content_type": "todos",
        });
        list<hash<auto>> records = map $1, rdp.searchRecords();

        assertEq(2, records.size(), "should have 2 written todos");
        assertEq("write-todo-001@test.com", records[0].uid);
        assertEq("Written Todo 1", records[0].summary);
        assertEq(2, records[0].priority);
        assertEq(50, records[0].percent_complete);
        assertEq("IN-PROCESS", records[0].status);
        assertEq("write-todo-002@test.com", records[1].uid);
        assertEq("Written Todo 2", records[1].summary);
        assertEq("NEEDS-ACTION", records[1].status);
    }

