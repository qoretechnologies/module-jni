    # =====================================================
    # Kotlin scripting tests
    # =====================================================

    private {
        bool scriptingJarsLoaded = False;
    }

    # Try to load Kotlin scripting JARs from common locations
    private bool tryLoadScriptingJars() {
        if (scriptingJarsLoaded) {
            return True;
        }

        # Check for scripting JARs in common locations
        list<string> scriptingPaths = (
            "/tmp/kotlin-scripting",  # Downloaded by download-kotlin-scripting-jars script
            (ENV.HOME ?? "") + "/.kotlin-scripting",
            ENV.KOTLIN_SCRIPTING_JARS ?? "",
        );

        object classloader = QoreURLClassLoader::getCurrent();

        foreach string basePath in (scriptingPaths) {
            if (!basePath || !is_dir(basePath)) {
                continue;
            }

            *list<string> jars = glob(basePath + "/*.jar");
            if (!jars) {
                continue;
            }

            # Found JARs, try to load them
            foreach string jar in (jars) {
                classloader.addPath(jar);
            }

            # Also add kotlin-reflect if available
            *string kotlin_home = find_kotlin_home();
            if (kotlin_home) {
                string reflectJar = kotlin_home + "/lib/kotlin-reflect.jar";
                if (is_file(reflectJar)) {
                    classloader.addPath(reflectJar);
                }
            }

            scriptingJarsLoaded = True;
            # Force retry of Kotlin scripting initialization now that JARs are loaded
            kotlin_scripting_retry();
            return True;
        }

        return False;
    }

    # Find KOTLIN_HOME directory
    private *string find_kotlin_home() {
        *string kotlin_home = ENV.KOTLIN_HOME;
        if (kotlin_home && is_dir(kotlin_home)) {
            return kotlin_home;
        }

        # Common locations
        list<string> homes = (
            "/opt/kotlin",
            "/opt/kotlinc",
            "/snap/kotlin/current",
            "/usr/share/kotlin",
            "/usr/lib/kotlin",
            "/usr/local/kotlin",
            "/opt/local/share/java/kotlin",
        );
        if (ENV.HOME) {
            homes += ENV.HOME + "/.sdkman/candidates/kotlin/current";
        }

        foreach string home in (homes) {
            if (is_dir(home)) {
                return home;
            }
        }

        # Try glob for snap
        *list<string> snap_paths = glob("/snap/kotlin/*/lib");
        if (snap_paths) {
            return dirname(snap_paths[0]);
        }

        return NOTHING;
    }

    kotlinScriptingAvailabilityTest() {
        # Test that kotlin_scripting_available() returns a boolean
        # Without scripting JARs, it should return False
        bool available = kotlin_scripting_available();
        assertEq(Type::Boolean, available.type());

        # Try to load scripting JARs
        tryLoadScriptingJars();

        # Check again - may or may not be True depending on whether JARs are present
        available = kotlin_scripting_available();
        assertEq(Type::Boolean, available.type());

        if (!available) {
            testSkip("Kotlin scripting JARs not available - skipping detailed scripting tests");
        }
    }

    kotlinEvalTest() {
        # Try to load scripting JARs first
        tryLoadScriptingJars();

        if (!kotlin_scripting_available()) {
            testSkip("Kotlin scripting JARs not available - run download-kotlin-scripting-jars to enable");
            return;
        }

        # Test basic arithmetic
        assertEq(3, kotlin_eval("1 + 2"));

        # Test string
        assertEq("Hello, Qore!", kotlin_eval("\"Hello, Qore!\""));

        # Test list operations
        assertEq(6, kotlin_eval("listOf(1, 2, 3).sum()"));

        # Test map creation
        hash<auto> result = kotlin_eval("mapOf(\"a\" to 1, \"b\" to 2)");
        assertEq(1, result.a);
        assertEq(2, result.b);

        # Test multiline script
        string script = "
            val x = 10
            val y = 20
            x + y
        ";
        assertEq(30, kotlin_eval(script));

        # Test error handling
        bool gotError = False;
        try {
            kotlin_eval("throw RuntimeException(\"test error\")");
        } catch (hash<auto> ex) {
            gotError = True;
            assertTrue(ex.desc.find("test error") >= 0, "Exception should contain error message");
        }
        assertTrue(gotError, "kotlin_eval should throw on script errors");
    }

    # =====================================================
    # QoreKotlinCompiler tests (dynamic compilation)
    # =====================================================

    private {
        bool compilerAvailable = False;
        lang::Class compilerClass;
    }

    private bool ensureKotlinCompilerAvailable() {
        if (compilerAvailable) {
            return True;
        }

        *string kotlin_home = find_kotlin_home();
        if (!kotlin_home) {
            return False;
        }

        string kotlin_compiler_jar = kotlin_home + "/lib/kotlin-compiler.jar";
        if (!is_file(kotlin_compiler_jar)) {
            return False;
        }

        object classloader = QoreURLClassLoader::getCurrent();
        classloader.addPath(kotlin_compiler_jar);

        # Now import QoreKotlinCompiler
        compilerClass = classloader.loadClass("org.qore.jni.compiler.QoreKotlinCompiler");
        compilerAvailable = True;
        return True;
    }

    kotlinCompilerBasicTest() {
        if (!ensureKotlinCompilerAvailable()) {
            testSkip("Kotlin compiler JAR not available");
            return;
        }

        # Test basic compilation without dynamic imports
        object compiler = compilerClass.getDeclaredConstructor().newInstance();
        on_exit compiler.close();

        string source = "
class SimpleClass {
    fun getMessage(): String = \"Hello from compiled Kotlin!\"

    fun add(a: Int, b: Int): Int = a + b
}
";
        hash<string, string> sources = {
            "SimpleClass": source,
        };

        hash<string, binary> result = compiler.compile(sources);

        # Verify we got bytecode
        assertTrue(result.hasKey("SimpleClass"), "Should have SimpleClass bytecode");
        assertTrue(result.SimpleClass.size() > 0, "SimpleClass bytecode should not be empty");

        # Load and test the compiled class
        object classloader = QoreURLClassLoader::getCurrent();
        classloader.addPendingClass("SimpleClass", result.SimpleClass);
        lang::Class cls = classloader.loadClass("SimpleClass");

        object obj = cls.getDeclaredConstructor().newInstance();
        assertEq("Hello from compiled Kotlin!", obj.getMessage());
        assertEq(15, obj.add(7, 8));
    }

    kotlinCompilerDynamicImportTest() {
        if (!ensureKotlinCompilerAvailable()) {
            testSkip("Kotlin compiler JAR not available");
            return;
        }

        # Test compilation with dynamic Qore imports
        object compiler = compilerClass.getDeclaredConstructor().newInstance();
        on_exit compiler.close();

        # Kotlin source that imports a Qore class
        string source = "
import qore.DynamicTestBase

class DynamicTestChild(name: String) : DynamicTestBase(name) {
    fun getGreeting(): String = greet(\"Hello\")

    fun getUpperName(): String = getName().uppercase()
}
";
        hash<string, string> sources = {
            "DynamicTestChild": source,
        };

        hash<string, binary> result = compiler.compile(sources);

        # Verify we got bytecode
        assertTrue(result.hasKey("DynamicTestChild"), "Should have DynamicTestChild bytecode");
        assertTrue(result.DynamicTestChild.size() > 0, "DynamicTestChild bytecode should not be empty");

        # Load and test the compiled class
        object classloader = QoreURLClassLoader::getCurrent();
        classloader.addPendingClass("DynamicTestChild", result.DynamicTestChild);
        lang::Class cls = classloader.loadClass("DynamicTestChild");

        # Create instance with constructor that takes String
        lang::Class stringClass = load_class("java/lang/String");
        Constructor ctor = cls.getConstructor((stringClass,));
        object obj = ctor.newInstance(("World",));

        # Test methods - these call through to the Qore base class
        assertEq("Hello, World!", obj.getGreeting());
        assertEq("WORLD", obj.getUpperName());
    }

    kotlinCompilerSyntaxErrorTest() {
        if (!ensureKotlinCompilerAvailable()) {
            testSkip("Kotlin compiler JAR not available");
            return;
        }

        # Test that compilation errors are properly reported
        object compiler = compilerClass.getDeclaredConstructor().newInstance();
        on_exit compiler.close();

        # Invalid Kotlin syntax - missing closing brace
        string source = "
class BrokenClass {
    fun broken(): String {
        return \"hello\"
    // missing closing brace
";
        hash<string, string> sources = {
            "BrokenClass": source,
        };

        bool gotError = False;
        try {
            compiler.compile(sources);
        } catch (hash<ExceptionInfo> ex) {
            gotError = True;
            # Verify it's a compilation error
            assertTrue(ex.err == "JNI-ERROR" || ex.desc.find("error") >= 0 || ex.desc.find("Error") >= 0,
                "Should get a compilation error");
        }
        assertTrue(gotError, "Compilation of invalid syntax should throw an exception");
    }

    kotlinCompilerCloseIdempotentTest() {
        if (!ensureKotlinCompilerAvailable()) {
            testSkip("Kotlin compiler JAR not available");
            return;
        }

        # Test that close() can be called multiple times without error
        object compiler = compilerClass.getDeclaredConstructor().newInstance();

        # Call close multiple times - should not throw
        bool noError = True;
        try {
            compiler.close();
            compiler.close();
            compiler.close();
        } catch (hash<ExceptionInfo> ex) {
            noError = False;
        }
        assertTrue(noError, "close() should be idempotent - multiple calls should not throw");
    }
}
